---
/**
 * ChiroSmarts logo. Uses the canonical brand artwork (public/logo.png) keyed to
 * a transparent background and recolored white for the dark site theme
 * (public/logo-light.png). The certificate embeds the dark variant separately
 * (src/lib/logo-data.ts).
 */
interface Props {
  height?: number; // px height of the mark
}
const { height = 36 } = Astro.props;
---

<img
  src="/logo-light.png"
  alt="ChiroSmarts"
  height={height}
  style={`height:${height}px;width:auto;display:block`}
/>
