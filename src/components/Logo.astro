---
/**
 * ChiroSmarts logo. The light site theme (canvas #FAFAF7 / white surfaces) uses
 * the canonical dark brand artwork (public/logo.png). A white recolor remains at
 * public/logo-light.png for dark placements (e.g. a brand-teal footer).
 */
interface Props {
  height?: number; // px height of the mark
  variant?: "dark" | "light"; // dark = canonical (default); light = white recolor
}
const { height = 36, variant = "dark" } = Astro.props;
const src = variant === "light" ? "/logo-light.png" : "/logo.png";
---

<img
  src={src}
  alt="ChiroSmarts"
  height={height}
  style={`height:${height}px;width:auto;display:block`}
/>
