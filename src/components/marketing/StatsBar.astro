---
/** Owner-supplied stats. Renders NOTHING when absent — never a fake number. */
import { OWNER } from "@/config/marketing";
const stats = OWNER.stats;
---

{
  stats.length > 0 && (
    <section class="mk-section" style="padding:1.75rem 0;background:var(--bg-2)">
      <div class="mk-container" style="display:flex;gap:2rem;flex-wrap:wrap;justify-content:center;text-align:center">
        {stats.map((s) => (
          <div>
            <div style="font-size:2rem;font-weight:700;color:var(--text)">{s.value}</div>
            <div style="color:var(--muted);font-size:0.9rem">{s.label}</div>
          </div>
        ))}
      </div>
    </section>
  )
}
