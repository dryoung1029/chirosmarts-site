---
/** Sticky bottom CTA bar (mobile only) — course title + price + button. CSS-only. */
interface Props {
  title: string;
  price: string; // already formatted, e.g. "$39"
  href: string;
  label: string;
}
const { title, price, href, label } = Astro.props;
---

<div class="sticky-cta">
  <div class="sticky-cta-inner mk-container">
    <span class="sticky-cta-meta">
      <strong>{title}</strong> · {price}
    </span>
    <a class="btn-primary" href={href} style="padding:0.5rem 1rem">{label}</a>
  </div>
</div>

<style>
  .sticky-cta {
    position: fixed; left: 0; right: 0; bottom: 0; z-index: 40;
    background: var(--panel); border-top: 1px solid var(--border);
    display: none;
  }
  .sticky-cta-inner {
    display: flex; align-items: center; justify-content: space-between; gap: 0.75rem;
    padding-top: 0.6rem; padding-bottom: 0.6rem;
  }
  .sticky-cta-meta { font-size: 0.9rem; color: var(--muted); }
  @media (max-width: 720px) {
    .sticky-cta { display: block; }
    body { padding-bottom: 4rem; }
  }
</style>
