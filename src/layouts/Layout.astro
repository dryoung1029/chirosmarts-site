---
interface Props {
  title: string;
  showNav?: boolean;
}
const { title, showNav = false } = Astro.props;
const user = Astro.locals.user;
import "@/styles/tokens.css";
import Logo from "@/components/Logo.astro";
import { isAdmin } from "@/lib/admin";
import { LEGAL } from "@/config/legal";
const userIsAdmin = isAdmin(Astro.locals.runtime.env, user);
const isClinicOwner = user?.role === "clinic_admin";
const legalEntity = LEGAL.entityName;
const impersonating = Astro.locals.impersonating;
const realUser = Astro.locals.realUser;
// Highlight the active top-level section.
const path = Astro.url.pathname;
const isActive = (prefix: string) =>
  prefix === "/dashboard" ? path === "/dashboard" : path.startsWith(prefix);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · ChiroSmarts</title>
    <style is:global>
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        min-height: 100vh;
      }
      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
      }
      .nav strong { font-size: 1.1rem; }
      .nav form { margin: 0; }
      .nav-links { display: flex; align-items: center; gap: 1.25rem; }
      .nav-links a { font-size: 0.95rem; text-decoration: none; color: var(--muted); }
      .nav-links a:hover { color: var(--text); }
      .nav-links a.active { color: var(--text); font-weight: 600; }
      .wrap { max-width: 44rem; margin: 0 auto; padding: 2rem 1.5rem; }
      .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1.25rem;
        box-shadow: var(--shadow);
      }
      h1 { font-size: 1.6rem; margin: 0 0 0.5rem; }
      h2 { font-size: 1.1rem; margin: 0 0 0.75rem; }
      p { line-height: 1.5; color: var(--muted); }
      label { display: block; font-size: 0.9rem; margin: 0.9rem 0 0.3rem; }
      .row { display: flex; gap: 1rem; }
      .row > div { flex: 1; }
      .check { display: flex; gap: 0.6rem; align-items: flex-start; margin-top: 1rem; }
      .check input { width: auto; margin-top: 0.25rem; }
      /* Keep the in-content form-button spacing the app relied on. */
      .wrap button, .wrap .btn { margin-top: 1.25rem; }
      .wrap button.link { margin-top: 0; }
      .muted { color: var(--muted); font-size: 0.9rem; }
    </style>
  </head>
  <body>
    {
      impersonating && (
        <div style="background:var(--warn);color:#fff;padding:0.6rem 1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;font-size:0.9rem">
          <span>
            👁 Viewing as{" "}
            <strong>{user?.displayName || user?.legalName || user?.email}</strong>{" "}
            (read-only preview)
            {realUser && (
              <span style="opacity:0.85"> · signed in as {realUser.email}</span>
            )}
          </span>
          <form method="POST" action="/api/impersonate/stop" style="margin:0">
            <button
              class="link"
              type="submit"
              style="margin:0;color:#fff;text-decoration:underline;font-weight:600"
            >
              Exit preview
            </button>
          </form>
        </div>
      )
    }
    {
      showNav && (
        <nav class="nav">
          <a href="/dashboard" style="text-decoration:none;color:inherit"><Logo height={42} /></a>
          {user && (
            <div style="display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap">
              <div class="nav-links">
                <a href="/dashboard" class={isActive("/dashboard") ? "active" : ""}>Dashboard</a>
                {isClinicOwner && (
                  <a href="/clinic" class={isActive("/clinic") ? "active" : ""}>Clinic</a>
                )}
                {userIsAdmin && (
                  <a href="/admin" class={isActive("/admin") ? "active" : ""}>Admin</a>
                )}
                <a href="/help" class={isActive("/help") ? "active" : ""}>Help</a>
              </div>
              <form method="POST" action="/api/auth/logout" style="display:flex;align-items:center;gap:1rem">
                <span class="muted">{user.email}</span>
                <button class="link" type="submit">Sign out</button>
              </form>
            </div>
          )}
        </nav>
      )
    }
    <main class="wrap">
      <slot />
    </main>
    <footer class="wrap" style="margin-top:2rem;padding:1.25rem 0;border-top:1px solid var(--border);color:var(--muted);font-size:0.85rem;display:flex;gap:1rem;flex-wrap:wrap;align-items:center">
      <span>© {new Date().getFullYear()} {legalEntity}</span>
      <a href="/help">Help</a>
      <a href="/terms">Terms of Service</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/courses">Courses</a>
    </footer>
  </body>
</html>
