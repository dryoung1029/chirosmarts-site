---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import RequirementsTable from "@/components/marketing/RequirementsTable.astro";
import CertificatePreview from "@/components/marketing/CertificatePreview.astro";
import Testimonials from "@/components/marketing/Testimonials.astro";
import Faq from "@/components/marketing/Faq.astro";
import StickyCta from "@/components/marketing/StickyCta.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import type { IllustrationName } from "@/lib/illustration-manifest";
import { getDb, schema } from "@/db/client";
import { and, eq } from "drizzle-orm";
import { getCourseBySlug, getCourseStructure } from "@/lib/courses";
import { getSiteUrl } from "@/lib/env";
import { courseLd, faqPageLd } from "@/lib/structured-data";
import { COURSE_MARKETING } from "@/config/marketing";

const env = Astro.locals.runtime.env;
const db = getDb(env);
const user = Astro.locals.user;
const { slug } = Astro.params;

const course = await getCourseBySlug(db, slug!);
if (!course || course.status !== "published") return Astro.redirect("/courses", 302);

const structure = await getCourseStructure(db, course.id);
const hasFreePreview = structure.some(({ module }) => module.isFreePreview);

let isEnrolled = false;
if (user) {
  const e = await db
    .select({ status: schema.enrollments.status })
    .from(schema.enrollments)
    .where(and(eq(schema.enrollments.userId, user.id), eq(schema.enrollments.courseId, course.id)))
    .get();
  isEnrolled = !!e && (e.status === "active" || e.status === "completed");
}

const mk = COURSE_MARKETING[course.slug] ?? {};
// Decorative per-course illustration (square AR). Slugs without a mapping simply
// render no syllabus visual — see PLAN.md for unfilled slots.
const courseIllos: Record<string, IllustrationName> = {
  "oregon-ca-initial": "hands-on-training", // 05
  "vitals-monitoring": "vitals", // 06
};
const courseIllo = courseIllos[course.slug];
const usd = (c: number) => `$${(c / 100).toFixed(0)}`;
const canceled = Astro.url.searchParams.get("canceled");
const siteUrl = getSiteUrl(env).replace(/\/$/, "");

const ld = [courseLd(course, siteUrl), faqPageLd(mk.faqs ?? [])].filter(Boolean);
---

<MarketingLayout
  title={course.title}
  description={course.description ?? `${course.title} — ${course.creditHours} credit hours. Online, state-compliant CE from ChiroSmarts.`}
  canonicalPath={`/courses/${course.slug}`}
  jsonLd={ld}
>
  <section class="mk-section" style="padding-bottom:1.5rem">
    <div class="mk-container">
      <p style="margin:0 0 0.5rem"><a href="/courses">← All courses</a></p>
      <div style="display:grid;grid-template-columns:1.4fr 1fr;gap:2rem;align-items:start" class="course-head">
        <div>
          <h1 style="margin:0 0 0.4rem;font-size:2rem">{course.title}</h1>
          <p style="margin:0 0 1rem;color:var(--muted)">
            {course.creditHours} credit hour{course.creditHours === 1 ? "" : "s"} · Instructor: {course.instructorName}
          </p>
          {canceled && (
            <div class="mk-card" style="border-color:var(--warn);margin-bottom:1rem">Checkout canceled — you can enroll any time.</div>
          )}
          {course.description && <p style="font-size:1.05rem">{course.description}</p>}

          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;margin-top:1rem">
            <span style="font-size:1.6rem;font-weight:700">{usd(course.priceCents)}</span>
            {isEnrolled ? (
              <a class="btn-primary" href={`/learn/${course.slug}`}>Go to your course →</a>
            ) : user ? (
              <form method="POST" action="/api/checkout/course" style="margin:0">
                <input type="hidden" name="courseId" value={course.id} />
                <button class="btn-primary" type="submit">Enroll — {usd(course.priceCents)}</button>
              </form>
            ) : (
              <a class="btn-primary" href={`/login?next=${encodeURIComponent(`/courses/${course.slug}`)}`}>Enroll — {usd(course.priceCents)}</a>
            )}
            {hasFreePreview && !isEnrolled && (
              <a class="btn-secondary" href={`/login?next=${encodeURIComponent(`/learn/${course.slug}`)}`}>Try Module 1 free</a>
            )}
          </div>
          <p style="margin:0.75rem 0 0;color:var(--muted);font-size:0.85rem">
            14-day refund if you haven't passed the final exam or received a certificate. See our <a href="/terms">Terms</a>.
          </p>
        </div>
        <CertificatePreview courseTitle={course.title} creditHours={course.creditHours} instructorName={course.instructorName} />
      </div>
    </div>
  </section>

  <RequirementsTable rows={mk.requirements} verifyNote={mk.requirementsVerify} />

  <!-- Syllabus -->
  <section class="mk-section" style="padding-top:0">
    <div class:list={["mk-container", { "syllabus-wrap": courseIllo }]} style="max-width:820px">
      {courseIllo && <Illustration name={courseIllo} maxWidth={240} class="syllabus-illo" />}
      <div>
      <h2 style="margin-top:0">What's included</h2>
      {structure.length === 0 ? (
        <p style="color:var(--muted)">Course content is being finalized.</p>
      ) : (
        <ol style="padding-left:1.2rem">
          {structure.map(({ module, lessons }) => (
            <li style="margin:0.4rem 0">
              <strong style="color:var(--text)">{module.title}</strong>
              {module.description && <span style="color:var(--muted)"> — {module.description}</span>}
              <span style="color:var(--muted)"> ({lessons.length} lesson{lessons.length === 1 ? "" : "s"})</span>
            </li>
          ))}
        </ol>
      )}
      </div>
    </div>
  </section>

  <Testimonials heading="What students say" courseTag={course.slug} />

  <Faq faqs={mk.faqs ?? []} heading="Course FAQ" />

  <!-- Final CTA -->
  <section class="mk-section" style="text-align:center;background:var(--bg-2)">
    <div class="mk-container">
      <Illustration name="certificate-moment" maxWidth={220} style="margin:0 auto 1rem" />
      <h2 style="margin-bottom:0.75rem">Ready to start?</h2>
      {isEnrolled ? (
        <a class="btn-primary" href={`/learn/${course.slug}`}>Go to your course →</a>
      ) : user ? (
        <form method="POST" action="/api/checkout/course" style="margin:0">
          <input type="hidden" name="courseId" value={course.id} />
          <button class="btn-primary" type="submit">Enroll now — {usd(course.priceCents)}</button>
        </form>
      ) : (
        <a class="btn-primary" href={`/login?next=${encodeURIComponent(`/courses/${course.slug}`)}`}>Sign in to enroll</a>
      )}
    </div>
  </section>

  {!isEnrolled && (
    <StickyCta
      title={course.title}
      price={usd(course.priceCents)}
      href={user ? "#" : `/login?next=${encodeURIComponent(`/courses/${course.slug}`)}`}
      label="Enroll"
    />
  )}

  <style>
    @media (max-width: 760px) { .course-head { grid-template-columns: 1fr !important; } }
    .syllabus-wrap { display: grid; grid-template-columns: 240px 1fr; gap: 1.5rem; align-items: start; }
    @media (max-width: 640px) {
      .syllabus-wrap { grid-template-columns: 1fr; }
      .syllabus-wrap .syllabus-illo { margin: 0 auto; }
    }
  </style>
</MarketingLayout>
