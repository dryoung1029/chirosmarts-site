---
import Layout from "@/layouts/Layout.astro";
import { getDb, schema } from "@/db/client";
import { and, eq } from "drizzle-orm";
import { getCourseBySlug, getCourseStructure } from "@/lib/courses";

const env = Astro.locals.runtime.env;
const db = getDb(env);
const user = Astro.locals.user;
const { slug } = Astro.params;

const course = await getCourseBySlug(db, slug!);
if (!course || course.status !== "published") return Astro.redirect("/courses", 302);

const structure = await getCourseStructure(db, course.id);

let isEnrolled = false;
if (user) {
  const e = await db
    .select({ status: schema.enrollments.status })
    .from(schema.enrollments)
    .where(
      and(
        eq(schema.enrollments.userId, user.id),
        eq(schema.enrollments.courseId, course.id),
      ),
    )
    .get();
  isEnrolled = !!e && (e.status === "active" || e.status === "completed");
}

const usd = (cents: number) => `$${(cents / 100).toFixed(0)}`;
const canceled = Astro.url.searchParams.get("canceled");
---

<Layout title={course.title} showNav={true}>
  <p style="margin:0"><a href="/courses">← All courses</a></p>
  <h1 style="margin-bottom:0.25rem">{course.title}</h1>
  <p class="muted" style="margin-top:0">
    {course.creditHours} credit hour{course.creditHours === 1 ? "" : "s"} ·
    Instructor: {course.instructorName}
  </p>

  {canceled && <div class="notice warn">Checkout canceled — you can enroll any time.</div>}

  {course.description && <p>{course.description}</p>}

  <div class="panel">
    <h2 style="margin-top:0">What's included</h2>
    {
      structure.length === 0 ? (
        <p class="muted" style="margin:0">Course content is being finalized.</p>
      ) : (
        <ol style="margin:0;padding-left:1.2rem">
          {structure.map(({ module, lessons }) => (
            <li style="margin:0.35rem 0">
              <strong style="color:var(--text)">{module.title}</strong>
              {module.description && (
                <span class="muted"> — {module.description}</span>
              )}
              <span class="muted"> ({lessons.length} lesson{lessons.length === 1 ? "" : "s"})</span>
            </li>
          ))}
        </ol>
      )
    }
  </div>

  <div class="panel" style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
    <div style="font-size:1.5rem;font-weight:700;color:var(--text)">{usd(course.priceCents)}</div>
    {
      isEnrolled ? (
        <a class="btn" href={`/learn/${course.slug}`} style="margin:0">Go to your course →</a>
      ) : user ? (
        <form method="POST" action="/api/checkout/course" style="margin:0">
          <input type="hidden" name="courseId" value={course.id} />
          <button type="submit" style="margin:0">Enroll now</button>
        </form>
      ) : (
        <a class="btn" href={`/login?next=${encodeURIComponent(`/courses/${course.slug}`)}`} style="margin:0">
          Sign in to enroll
        </a>
      )
    }
    {!isEnrolled && (
      <p class="muted" style="margin:0;font-size:0.82rem;flex-basis:100%">
        By purchasing you agree to the <a href="/terms">Terms of Service</a>.
      </p>
    )}
  </div>
</Layout>
