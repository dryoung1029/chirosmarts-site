---
import { getSiteUrl } from "@/lib/env";

const env = Astro.locals.runtime?.env;
// Read SITE_URL from the environment (never hard-coded). In `astro dev` the
// Cloudflare platform proxy supplies it from .dev.vars.
let siteUrl = "(runtime not available)";
try {
  if (env) siteUrl = getSiteUrl(env);
} catch (e) {
  siteUrl = `⚠ ${(e as Error).message}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ChiroSmarts — coming soon</title>
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0f172a;
        color: #e2e8f0;
      }
      main { text-align: center; padding: 2rem; max-width: 36rem; }
      h1 { font-size: 2rem; margin-bottom: 0.5rem; }
      p { color: #94a3b8; line-height: 1.5; }
      code {
        background: #1e293b;
        padding: 0.15rem 0.4rem;
        border-radius: 0.3rem;
        color: #7dd3fc;
      }
      .badge {
        display: inline-block;
        margin-top: 1.5rem;
        font-size: 0.8rem;
        color: #64748b;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>ChiroSmarts</h1>
      <p>
        Oregon Chiropractic Assistant training &amp; continuing education.
        The new platform is being built — milestone&nbsp;M0 (scaffold).
      </p>
      <p>
        Serving from <code>{siteUrl}</code>
      </p>
      <span class="badge">SSR on Cloudflare · status: scaffold</span>
    </main>
  </body>
</html>
