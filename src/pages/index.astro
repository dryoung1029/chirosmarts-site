---
// Public landing page.
import Logo from "@/components/Logo.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ChiroSmarts — Oregon Chiropractic Assistant training</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Questrial&display=swap"
      rel="stylesheet"
    />
    <style>
      :root { color-scheme: light dark; }
      body {
        font-family: system-ui, sans-serif;
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #0f172a;
        color: #e2e8f0;
      }
      main { text-align: center; padding: 2rem; max-width: 40rem; }
      h1 { font-size: 2rem; margin-bottom: 0.5rem; }
      p { color: #94a3b8; line-height: 1.55; }
      .cta {
        display: inline-block;
        margin-top: 0.5rem;
        background: #0ea5e9;
        color: #fff;
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        text-decoration: none;
      }
      .disclaimer {
        margin: 1.75rem auto 0;
        max-width: 34rem;
        text-align: left;
        background: #0b2942;
        border: 1px solid #1e496b;
        color: #cfe8ff;
        border-radius: 10px;
        padding: 1rem 1.15rem;
        font-size: 0.95rem;
        line-height: 1.5;
      }
    </style>
  </head>
  <body>
    <main>
      <div style="display:flex;justify-content:center;margin-bottom:0.75rem">
        <Logo height={46} />
      </div>
      <p>
        State-compliant Oregon Chiropractic Assistant training &amp; continuing
        education.
      </p>
      <p><a class="cta" href="/login">Sign in / Create account</a></p>

      <p class="disclaimer">
        <strong>Please note:</strong> ChiroSmarts training and its final exam
        confirm that you have completed and understood the coursework. They are
        <strong>not</strong> the certification exam. Becoming a certified Oregon
        Chiropractic Assistant requires passing the separate certification exam
        administered through the NBCE.
      </p>
    </main>
  </body>
</html>
