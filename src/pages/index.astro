---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import HeroDemo from "@/components/marketing/HeroDemo.astro";
import StatsBar from "@/components/marketing/StatsBar.astro";
import Testimonials from "@/components/marketing/Testimonials.astro";
import Faq from "@/components/marketing/Faq.astro";
import LeadCapture from "@/components/marketing/LeadCapture.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import { getDb, schema } from "@/db/client";
import { eq, asc } from "drizzle-orm";
import { OWNER, ownerCopy } from "@/config/marketing";

const db = getDb(Astro.locals.runtime.env);
// The Oregon CA initial certification is the flagship — it always leads the
// catalog teaser and gets a highlighted card, ahead of the cheaper CE add-ons.
const FLAGSHIP_SLUG = "oregon-ca-initial";
const publishedCourses = await db
  .select()
  .from(schema.courses)
  .where(eq(schema.courses.status, "published"))
  .orderBy(asc(schema.courses.priceCents))
  .all();
const courses = [...publishedCourses].sort((a, b) => {
  if (a.slug === FLAGSHIP_SLUG) return -1;
  if (b.slug === FLAGSHIP_SLUG) return 1;
  return a.priceCents - b.priceCents;
});
const usd = (c: number) => `$${(c / 100).toFixed(0)}`;

const heroHeadline = OWNER.hero.headline ?? ownerCopy("hero headline");
const heroSubhead = OWNER.hero.subhead ?? ownerCopy("hero subhead");
const instructor = OWNER.instructor;

const audience = [
  { title: "I'm becoming a CA", desc: "New to the field? See every step from hired to certified.", cta: "Start here →", href: "/guides/become-a-chiropractic-assistant-oregon", illo: "becoming-ca" as const },
  { title: "I need to renew", desc: "Find your deadline and exactly which hours Oregon requires of you this year.", cta: "Check my date →", href: "/renewal", illo: "time-to-renew" as const },
  { title: "I run a clinic", desc: "Buy seats, invite your team, and watch every certification stay current.", cta: "See how →", href: "/clinics", illo: "run-a-clinic" as const },
];
const steps = [
  { n: "1", t: "Sign up, get your roadmap.", d: "Answer five questions; we build your personal step-by-step Oregon path — training, paperwork, exam, deadlines." },
  { n: "2", t: "Train at your pace.", d: "Watch on any device, pick up where you left off, pass the final exam. Your hours are tracked automatically." },
  { n: "3", t: "Certified — and never caught off guard again.", d: "Your certificate is issued instantly, verifiable by any employer, and your renewal deadline is tracked for you every year." },
];
---

<MarketingLayout
  title="ChiroSmarts — Oregon Chiropractic Assistant training"
  description="Oregon CA certification training online — state-required hours, exam prep, verifiable certificates, and automatic renewal tracking. Module 1 free."
  canonicalPath="/"
>
  <!-- Hero -->
  <section class="mk-section" style="padding-top:2.5rem">
    <div class="mk-container hero-wrap">
      <div class="hero-copy">
        <h1 style="font-size:2.4rem;line-height:1.15;margin:0 0 0.75rem">
          {heroHeadline.startsWith("[OWNER COPY") ? <span class="owner-copy">{heroHeadline}</span> : heroHeadline}
        </h1>
        <p style="font-size:1.1rem;color:var(--muted);margin:0 0 1.5rem;max-width:34rem">
          {heroSubhead.startsWith("[OWNER COPY") ? <span class="owner-copy">{heroSubhead}</span> : heroSubhead}
        </p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap">
          <a class="btn-primary" href="/login">Start free — Module 1 is on us</a>
          <a class="btn-secondary" href="/clinics">For clinics →</a>
        </div>
        <p class="hero-trust">Trusted by 660+ Oregon CAs since 2015 · No card needed to start</p>
      </div>
      <div class="hero-demo-col">
        <HeroDemo />
      </div>
    </div>
  </section>

  <!-- Audience router -->
  <section class="mk-section" style="padding-top:0">
    <div class="mk-container mk-grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr))">
      {audience.map((a) => (
        <a class="mk-card" href={a.href} style="text-decoration:none;color:inherit">
          <Illustration name={a.illo} maxWidth={160} style="margin:0 auto 0.75rem" />
          <strong style="color:var(--text);font-size:1.05rem">{a.title}</strong>
          <p style="margin:0.4rem 0 0;color:var(--muted)">{a.desc}</p>
          <span style="color:var(--accent);font-size:0.9rem">{a.cta}</span>
        </a>
      ))}
    </div>
  </section>

  <StatsBar />

  <!-- How it works -->
  <section class="mk-section">
    <div class="mk-container">
      <div class="how-head">
        <div>
          <h2 style="margin-top:0">How it works</h2>
          <p style="margin:0;color:var(--muted);max-width:34rem">Train on your own schedule — most students finish in a couple of evenings, with their hours and renewal tracked automatically.</p>
        </div>
        <Illustration name="evening-study" maxWidth={340} class="how-illo" />
      </div>
      <div class="mk-grid" style="grid-template-columns:repeat(auto-fit,minmax(240px,1fr))">
        {steps.map((s) => (
          <div class="mk-card">
            <div style="width:34px;height:34px;border-radius:50%;background:var(--accent);color:var(--accent-text);display:grid;place-items:center;font-weight:700">{s.n}</div>
            <h3 style="margin:0.6rem 0 0.3rem;font-size:1.1rem">{s.t}</h3>
            <p style="margin:0;color:var(--muted)">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Instructor credibility -->
  <section class="mk-section" style="background:var(--bg-2)">
    <div class="mk-container" style="display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap">
      {instructor.photo
        ? <img src={instructor.photo} alt={instructor.name ?? "Instructor"} width="120" height="120" loading="lazy" style="border-radius:14px;object-fit:cover" />
        : <div style="width:120px;height:120px;border-radius:14px;background:var(--panel);border:1px dashed var(--border);display:grid;place-items:center;color:var(--muted);font-size:0.8rem;text-align:center">photo</div>}
      <div style="flex:1;min-width:240px">
        <h2 style="margin:0 0 0.25rem">
          {instructor.name ? instructor.name : <span class="owner-copy">{ownerCopy("instructor name")}</span>}
        </h2>
        <p style="margin:0 0 0.5rem;color:var(--accent)">
          {instructor.credentials ? instructor.credentials : <span class="owner-copy">{ownerCopy("instructor credentials")}</span>}
        </p>
        <p style="margin:0;color:var(--muted)">
          {instructor.bio ? instructor.bio : <span class="owner-copy">{ownerCopy("instructor short bio")}</span>}
        </p>
      </div>
    </div>
  </section>

  <Testimonials />

  <!-- Catalog teaser -->
  <section class="mk-section">
    <div class="mk-container">
      <h2>Courses</h2>
      <div class="mk-grid" style="grid-template-columns:repeat(auto-fill,minmax(240px,1fr))">
        {courses.map((c) => {
          const featured = c.slug === FLAGSHIP_SLUG;
          return (
          <a class={`mk-card${featured ? " course-featured" : ""}`} href={`/courses/${c.slug}`} style="text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:0.4rem">
            {featured && (
              <span style="align-self:flex-start;font-size:0.75rem;font-weight:700;letter-spacing:0.02em;padding:0.1rem 0.5rem;border-radius:6px;background:var(--accent);color:var(--accent-text)">★ Start here — required to certify</span>
            )}
            <strong style={`color:var(--text);${featured ? "font-size:1.3rem" : ""}`}>{c.title}</strong>
            <span style={`font-size:0.9rem;${featured ? "color:var(--text);font-weight:600" : "color:var(--muted)"}`}>{c.creditHours} credit hour{c.creditHours === 1 ? "" : "s"} · {usd(c.priceCents)}{featured && <span class="muted" style="font-weight:400"> · Module 1 free</span>}</span>
            <span style="color:var(--accent);font-size:0.9rem;font-weight:600">{featured ? "Start free — Module 1 is on us →" : "View course →"}</span>
          </a>
        );
        })}
      </div>
    </div>
  </section>

  <!-- Lead magnet -->
  <section id="get-checklist" class="mk-section" style="padding-top:0">
    <div class="mk-container" style="max-width:680px">
      <LeadCapture
        source="checklist_pdf"
        heading="Free: the Oregon CA Certification Checklist"
        blurb="Every step from job offer to certificate — the training hours, the hands-on log, the state application, the exam — on one printable page. Enter your email and we'll send it over."
        buttonLabel="Send me the checklist"
      />
      <p class="muted" style="font-size:0.82rem;margin:0.5rem 0 0">
        No spam. One useful PDF and an unsubscribe link in every email.
      </p>
    </div>
  </section>

  <Faq faqs={OWNER.homepageFaq} />

  <!-- Existing compliance disclaimer (owner copy — preserved) -->
  <section class="mk-section" style="padding-top:0">
    <div class="mk-container">
      <div class="mk-card" style="border-color:var(--brand);background:var(--brand-tint);color:var(--ink)">
        <strong>Please note:</strong> ChiroSmarts training and its final exam confirm
        that you have completed and understood the coursework. They are
        <strong>not</strong> the certification exam. Becoming a certified Oregon
        Chiropractic Assistant requires passing the separate certification exam
        administered through the NBCE.
      </div>
    </div>
  </section>

  <style>
    .hero-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: center; }
    .hero-trust { margin: 0.9rem 0 0; color: var(--muted); font-size: 0.9rem; }
    /* Flagship course card leads the catalog teaser full-width with an accent
       border + brand-tinted gradient so it doesn't blend with the CE add-ons. */
    .course-featured {
      grid-column: 1 / -1;
      border: 2px solid var(--brand);
      background: linear-gradient(135deg, var(--brand-tint), var(--surface));
      box-shadow: var(--shadow);
    }
    .how-head { display: flex; gap: 2rem; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
    .how-head .how-illo { flex: 0 0 auto; }
    @media (max-width: 880px) {
      .hero-wrap { grid-template-columns: 1fr; }
      /* Lead with the message on mobile — headline, value prop, and CTA come
         first, then the dashboard demo as supporting proof below. (Previously
         the demo was force-ordered above the copy, so phone visitors landed on
         a context-free mockup at the widest part of the funnel.) */
      .hero-copy { text-align: center; }
      .hero-copy > div { justify-content: center; }
      .hero-demo-col { margin-top: 0.5rem; }
    }
    @media (max-width: 720px) {
      .how-head { flex-direction: column; align-items: flex-start; }
      .how-head .how-illo { margin: 0.5rem auto 0; }
    }
  </style>
</MarketingLayout>
