---
/**
 * Article Studio — post editor. Edit fields + Markdown body, AI "Apply edit",
 * publish/unpublish, preview, delete. Admin-guarded by middleware.
 */
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import BusyOverlay from "@/components/BusyOverlay.astro";
import { getDb, schema } from "@/db/client";
import { eq } from "drizzle-orm";
import { extractFaqs, wordCount } from "@/lib/blog";

const db = getDb(Astro.locals.runtime.env);
const id = Astro.params.id!;
const post = await db
  .select()
  .from(schema.blogPosts)
  .where(eq(schema.blogPosts.id, id))
  .get();
if (!post) return Astro.redirect("/admin/blog", 303);

const msg = Astro.url.searchParams.get("msg");
const tags = (post.tags ?? []).join(", ");
const inp = "width:100%;padding:0.5rem;margin-bottom:0.9rem";

// SEO/AEO health checks on the current saved body (refreshes on Save).
const md = post.bodyMarkdown ?? "";
const head = md.slice(0, 700);
const metaLen = (post.seoDescription ?? "").length;
const internalLinks = (md.match(/\]\(\/(?!\/)/g) ?? []).length;
const externalLinks = (md.match(/\]\(https?:\/\//g) ?? []).length;
const faqCount = extractFaqs(md).length;
const wc = wordCount(md);
const checks = [
  { ok: wc >= 700, label: `Length: ${wc} words (aim 900–1400)` },
  { ok: /\*\*[^*\n]{40,}\*\*/.test(head), label: "Bold direct-answer paragraph up top (AI-extractable)" },
  { ok: /^##\s+key takeaways/im.test(md), label: "Key takeaways section" },
  { ok: faqCount >= 3, label: `FAQ section: ${faqCount} Q&A (powers FAQ rich results)` },
  { ok: internalLinks >= 2, label: `Internal links: ${internalLinks} (aim 2–4)` },
  { ok: externalLinks >= 1, label: `External/authority links: ${externalLinks} (e.g. OBCE)` },
  { ok: metaLen >= 70 && metaLen <= 160, label: `Meta description: ${metaLen} chars (aim 120–160)` },
];
---

<Layout title="Edit article · Admin" showNav={true}>
  <BusyOverlay />
  <AdminNav active="blog" />
  <p style="margin:0 0 0.5rem"><a href="/admin/blog">← All articles</a></p>
  {msg && (
    <p class="panel" style="margin:0 0 1rem;background:var(--brand-tint);color:var(--brand);border:none">{msg}</p>
  )}

  <div style="display:flex;align-items:baseline;gap:0.75rem;flex-wrap:wrap">
    <h1 style="margin:0">{post.title}</h1>
    <span
      style={`padding:0.15rem 0.6rem;border-radius:6px;font-size:0.8rem;${
        post.status === "published"
          ? "background:var(--brand-tint);color:var(--brand)"
          : "background:var(--panel-2);color:var(--muted)"
      }`}
    >{post.status}</span>
    {post.model && <span class="muted" style="font-size:0.85rem">drafted by {post.model}</span>}
  </div>
  <p class="muted" style="margin:0.25rem 0 1.25rem;font-size:0.9rem">Public URL: <code>/blog/{post.slug}</code></p>

  <details class="panel" style="margin:0 0 1.25rem" open>
    <summary style="font-weight:600;cursor:pointer">SEO / AEO checklist</summary>
    <ul style="list-style:none;margin:0.6rem 0 0;padding:0;display:flex;flex-direction:column;gap:0.3rem">
      {checks.map((c) => (
        <li style={`font-size:0.9rem;color:${c.ok ? "var(--brand)" : "var(--muted)"}`}>
          {c.ok ? "✓" : "○"} {c.label}
        </li>
      ))}
    </ul>
    <p class="muted" style="margin:0.6rem 0 0;font-size:0.82rem">Refreshes when you Save. These structure cues are what help the article rank and get quoted by AI answer engines.</p>
  </details>

  <form method="POST" action={`/api/admin/blog/${post.id}`}>
    <label style="font-weight:600">Title</label>
    <input type="text" name="title" value={post.title} required style={inp} />

    <div style="display:flex;gap:1rem;flex-wrap:wrap">
      <div style="flex:1;min-width:14rem">
        <label style="font-weight:600">Slug</label>
        <input type="text" name="slug" value={post.slug} style={inp} />
      </div>
      <div style="flex:1;min-width:14rem">
        <label style="font-weight:600">Tags (comma-separated)</label>
        <input type="text" name="tags" value={tags} placeholder="compliance, front desk" style={inp} />
      </div>
    </div>

    <label style="font-weight:600">Excerpt (list/preview text)</label>
    <textarea name="excerpt" style="width:100%;padding:0.5rem;height:3.5rem;margin-bottom:0.9rem">{post.excerpt}</textarea>

    <label style="font-weight:600">SEO meta description</label>
    <input type="text" name="seoDescription" value={post.seoDescription ?? ""} maxlength="180" style={inp} />

    <label style="font-weight:600">Body (Markdown)</label>
    <textarea
      name="bodyMarkdown"
      spellcheck="true"
      style="width:100%;height:26rem;padding:0.75rem;font-family:ui-monospace,Menlo,monospace;font-size:0.9rem;line-height:1.5;white-space:pre">{post.bodyMarkdown}</textarea>

    <label style="display:block;font-weight:600;margin:1.1rem 0 0.25rem">Ask for an edit (optional)</label>
    <input type="text" name="instruction" placeholder="e.g. Make the intro punchier, add a section on documentation" style="width:100%;padding:0.5rem" />
    <p class="muted" style="margin:0.3rem 0 0;font-size:0.85rem">"Apply edit" rewrites the body above in your voice. "Save" just saves your changes.</p>

    <div style="display:flex;gap:0.75rem;margin-top:1rem;flex-wrap:wrap">
      <button type="submit" class="btn-primary" style="padding:0.5rem 1.2rem">Save</button>
      <button type="submit" formaction={`/api/admin/blog/${post.id}/revise`} data-busy="Applying your edit…"
        style="padding:0.5rem 1.2rem;border-radius:8px;border:1px solid var(--accent);background:var(--brand-tint);color:var(--brand);font-weight:600">✦ Apply edit</button>
      <a href={`/blog/${post.slug}`} target="_blank" rel="noopener"
        style="padding:0.5rem 1.1rem;border-radius:8px;border:1px solid var(--border);background:var(--panel);text-decoration:none;color:var(--text)">Preview ↗</a>
    </div>
  </form>

  <hr style="margin:1.6rem 0;border:none;border-top:1px solid var(--border)" />

  <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap">
    <form method="POST" action={`/api/admin/blog/${post.id}/publish`}>
      <input type="hidden" name="action" value={post.status === "published" ? "unpublish" : "publish"} />
      <button type="submit" class="btn-primary" style="padding:0.5rem 1.2rem">
        {post.status === "published" ? "Unpublish" : "Publish to /blog"}
      </button>
    </form>
    {post.status === "published" && (
      <span class="muted" style="font-size:0.9rem">Live at <code>/blog/{post.slug}</code></span>
    )}
    <form id="delete-post" method="POST" action={`/api/admin/blog/${post.id}/delete`} style="margin-left:auto">
      <button type="submit" style="padding:0.45rem 1rem;border-radius:8px;border:1px solid var(--danger,#b3261e);background:transparent;color:var(--danger,#b3261e)">Delete</button>
    </form>
  </div>

  <script>
    document.getElementById("delete-post")?.addEventListener("submit", (e) => {
      if (!confirm("Delete this article? This can't be undone.")) e.preventDefault();
    });
  </script>
</Layout>
