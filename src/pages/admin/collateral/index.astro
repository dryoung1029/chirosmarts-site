---
/**
 * Collateral Studio — admin list (P1a scaffold).
 * Lists generated/published collateral grouped by course. Generation + editor +
 * publish land in P1b/P1c (docs/collateral-studio-design.md). Route is admin-
 * guarded by middleware (site_admin).
 */
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import { getDb, schema } from "@/db/client";
import { asc } from "drizzle-orm";

const db = getDb(Astro.locals.runtime.env);
const courses = await db.select().from(schema.courses).all();
const collateral = await db.select().from(schema.courseCollateral).all();
const modules = await db
  .select()
  .from(schema.modules)
  .orderBy(asc(schema.modules.position))
  .all();

const byCourse = new Map<string, typeof collateral>();
for (const c of collateral) {
  const list = byCourse.get(c.courseId) ?? [];
  list.push(c);
  byCourse.set(c.courseId, list);
}
const modsByCourse = new Map<string, typeof modules>();
for (const m of modules) {
  const list = modsByCourse.get(m.courseId) ?? [];
  list.push(m);
  modsByCourse.set(m.courseId, list);
}

const msg = Astro.url.searchParams.get("msg");

const TYPE_LABEL: Record<string, string> = {
  study_guide: "Study guide",
  checklist: "Checklist",
  cheat_sheet: "Cheat-sheet",
  glossary: "Glossary",
  practice_questions: "Practice questions",
  handout: "Handout",
};
---

<Layout title="Collateral · Admin" showNav={true}>
  <AdminNav active="collateral" />
  <h1>Collateral Studio</h1>
  <p class="muted" style="margin-top:0;max-width:48rem">
    Generate study guides, checklists, and cheat-sheets from a course's
    transcripts — in Dr. Young's voice — then edit them and (next step) publish
    as PDFs for students. Generation can take up to a minute for a whole course;
    pick a single module for faster, tighter results.
  </p>

  {msg && (
    <p
      class="panel"
      style="margin:0 0 1rem;background:var(--brand-tint);color:var(--brand);border:none"
    >
      {msg}
    </p>
  )}

  {
    courses.map((c) => {
      const items = byCourse.get(c.id) ?? [];
      return (
        <div class="panel" style="margin-bottom:1rem">
          <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <div style="flex:1;min-width:14rem">
              <div style="font-weight:600;color:var(--text)">{c.title}</div>
              <div class="muted" style="font-size:0.88rem">
                /{c.slug} · {items.length} collateral item{items.length === 1 ? "" : "s"}
              </div>
            </div>
            <form
              method="POST"
              action="/api/admin/collateral/generate"
              style="display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center"
            >
              <input type="hidden" name="courseId" value={c.id} />
              <select name="type" style="padding:0.35rem">
                <option value="study_guide">Study guide</option>
                <option value="checklist">Checklist</option>
                <option value="cheat_sheet">Cheat-sheet</option>
              </select>
              <select name="scope_ref" style="padding:0.35rem;max-width:14rem">
                <option value="course">Whole course</option>
                {(modsByCourse.get(c.id) ?? []).map((m) => (
                  <option value={`module:${m.id}`}>Module: {m.title}</option>
                ))}
              </select>
              <button type="submit" class="btn-primary" style="padding:0.4rem 0.9rem">
                Generate
              </button>
            </form>
          </div>

          {items.length > 0 && (
            <ul style="list-style:none;margin:0.75rem 0 0;padding:0;display:flex;flex-direction:column;gap:0.4rem">
              {items.map((it) => (
                <li style="display:flex;align-items:center;gap:0.6rem;font-size:0.92rem">
                  <a
                    href={`/admin/collateral/${it.id}`}
                    style="color:var(--accent);text-decoration:none;font-weight:500"
                  >
                    {it.title}
                  </a>
                  <span class="muted">· {TYPE_LABEL[it.type] ?? it.type}</span>
                  <span
                    style={`padding:0.1rem 0.5rem;border-radius:6px;font-size:0.78rem;${
                      it.status === "published"
                        ? "background:var(--brand-tint);color:var(--brand)"
                        : "background:var(--panel-2);color:var(--muted)"
                    }`}
                  >
                    {it.status}
                  </span>
                </li>
              ))}
            </ul>
          )}
        </div>
      );
    })
  }

  {courses.length === 0 && <p class="muted">No courses yet.</p>}
</Layout>
