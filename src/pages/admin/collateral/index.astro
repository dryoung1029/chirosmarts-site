---
/**
 * Collateral Studio — admin list (P1a scaffold).
 * Lists generated/published collateral grouped by course. Generation + editor +
 * publish land in P1b/P1c (docs/collateral-studio-design.md). Route is admin-
 * guarded by middleware (site_admin).
 */
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import BusyOverlay from "@/components/BusyOverlay.astro";
import { getDb, schema } from "@/db/client";
import { asc } from "drizzle-orm";

const db = getDb(Astro.locals.runtime.env);
const courses = await db.select().from(schema.courses).all();
const collateral = await db.select().from(schema.courseCollateral).all();
const modules = await db
  .select()
  .from(schema.modules)
  .orderBy(asc(schema.modules.position))
  .all();

const byCourse = new Map<string, typeof collateral>();
for (const c of collateral) {
  const list = byCourse.get(c.courseId) ?? [];
  list.push(c);
  byCourse.set(c.courseId, list);
}
for (const list of byCourse.values())
  list.sort(
    (a, b) => a.sortOrder - b.sortOrder || a.createdAt.localeCompare(b.createdAt),
  );
const modsByCourse = new Map<string, typeof modules>();
for (const m of modules) {
  const list = modsByCourse.get(m.courseId) ?? [];
  list.push(m);
  modsByCourse.set(m.courseId, list);
}

const msg = Astro.url.searchParams.get("msg");

const TYPE_LABEL: Record<string, string> = {
  study_guide: "Study guide",
  checklist: "Checklist",
  cheat_sheet: "Cheat-sheet",
  glossary: "Glossary",
  practice_questions: "Practice questions",
  handout: "Handout",
};
---

<Layout title="Collateral · Admin" showNav={true}>
  <BusyOverlay />
  <AdminNav active="collateral" />
  <h1>Collateral Studio</h1>
  <p class="muted" style="margin-top:0;max-width:48rem">
    Generate study guides, checklists, and cheat-sheets from a course's
    transcripts — in Dr. Young's voice — then edit them and (next step) publish
    as PDFs for students. Generation can take up to a minute for a whole course;
    pick a single module for faster, tighter results.
  </p>

  {msg && (
    <p
      class="panel"
      style="margin:0 0 1rem;background:var(--brand-tint);color:var(--brand);border:none"
    >
      {msg}
    </p>
  )}

  {
    courses.map((c) => {
      const items = byCourse.get(c.id) ?? [];
      const mods = modsByCourse.get(c.id) ?? [];
      const haveGuide = new Set(
        items
          .filter((it) => it.type === "study_guide" && it.scope === "module")
          .map((it) => it.scopeRefId),
      );
      const modulesNeeding = mods.filter((m) => !haveGuide.has(m.id));
      return (
        <div class="panel" style="margin-bottom:1rem">
          <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
            <div style="flex:1;min-width:14rem">
              <div style="font-weight:600;color:var(--text)">{c.title}</div>
              <div class="muted" style="font-size:0.88rem">
                /{c.slug} · {items.length} collateral item{items.length === 1 ? "" : "s"}
              </div>
            </div>
            <form
              method="POST"
              action="/api/admin/collateral/generate"
              data-busy="Generating from transcripts… this can take up to a minute."
              style="display:flex;gap:0.4rem;flex-wrap:wrap;align-items:center"
            >
              <input type="hidden" name="courseId" value={c.id} />
              <select name="type" style="padding:0.35rem">
                <option value="study_guide">Study guide</option>
                <option value="checklist">Checklist</option>
                <option value="cheat_sheet">Cheat-sheet</option>
              </select>
              <select name="scope_ref" style="padding:0.35rem;max-width:14rem">
                <option value="course">Whole course</option>
                {(modsByCourse.get(c.id) ?? []).map((m) => (
                  <option value={`module:${m.id}`}>Module: {m.title}</option>
                ))}
              </select>
              <button type="submit" class="btn-primary" style="padding:0.4rem 0.9rem">
                Generate
              </button>
            </form>
          </div>

          {modulesNeeding.length > 0 && (
            <div style="margin-top:0.7rem;display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap">
              <button
                type="button"
                class="genall-btn btn-primary"
                data-course={c.id}
                data-modules={JSON.stringify(
                  modulesNeeding.map((m) => ({ id: m.id, title: m.title })),
                )}
                style="padding:0.4rem 1rem"
              >
                ✨ Generate study guides for {modulesNeeding.length} module{modulesNeeding.length === 1 ? "" : "s"}
              </button>
              <span class="genall-progress muted" style="font-size:0.85rem"></span>
            </div>
          )}

          {items.length > 0 && (
            <>
              <ul style="list-style:none;margin:0.85rem 0 0;padding:0;display:flex;flex-direction:column">
                {items.map((it, idx) => (
                  <li style="display:flex;align-items:center;gap:0.5rem;font-size:0.9rem;border-top:1px solid var(--border);padding:0.45rem 0">
                    <span style="display:flex;flex-direction:column;line-height:0.7">
                      <form method="POST" action={`/api/admin/collateral/${it.id}/move`}>
                        <input type="hidden" name="dir" value="up" />
                        <button type="submit" disabled={idx === 0} title="Move up" style="border:none;background:none;cursor:pointer;color:var(--muted);font-size:0.7rem;padding:0">
                          ▲
                        </button>
                      </form>
                      <form method="POST" action={`/api/admin/collateral/${it.id}/move`}>
                        <input type="hidden" name="dir" value="down" />
                        <button type="submit" disabled={idx === items.length - 1} title="Move down" style="border:none;background:none;cursor:pointer;color:var(--muted);font-size:0.7rem;padding:0">
                          ▼
                        </button>
                      </form>
                    </span>

                    <form method="POST" action={`/api/admin/collateral/${it.id}/rename`} style="display:flex;gap:0.3rem;flex:1;min-width:12rem;align-items:center">
                      <input name="title" value={it.title} style="flex:1;padding:0.3rem;font-size:0.9rem" />
                      <button type="submit" title="Save name" style="padding:0.3rem 0.6rem;border:1px solid var(--border);background:var(--panel);border-radius:6px;color:var(--text);font-size:0.82rem">
                        Rename
                      </button>
                    </form>

                    <span class="muted" style="white-space:nowrap">{TYPE_LABEL[it.type] ?? it.type}</span>
                    <span
                      style={`padding:0.1rem 0.5rem;border-radius:6px;font-size:0.78rem;${
                        it.status === "published"
                          ? "background:var(--brand-tint);color:var(--brand)"
                          : "background:var(--panel-2);color:var(--muted)"
                      }`}
                    >
                      {it.status}
                    </span>

                    <form method="POST" action={`/api/admin/collateral/${it.id}/toggle-manual`}>
                      <button type="submit" title="Include in the compiled manual" style={`padding:0.15rem 0.55rem;border-radius:6px;font-size:0.78rem;border:1px solid ${it.inManual ? "var(--accent)" : "var(--border)"};background:${it.inManual ? "var(--brand-tint)" : "var(--panel)"};color:${it.inManual ? "var(--brand)" : "var(--muted)"};cursor:pointer`}>
                        {it.inManual ? "✓ in manual" : "add to manual"}
                      </button>
                    </form>

                    <a href={`/admin/collateral/${it.id}`} style="white-space:nowrap">Edit →</a>
                  </li>
                ))}
              </ul>

              <form method="POST" action="/api/admin/collateral/compile-manual" data-busy="Compiling the manual…" style="margin-top:0.85rem">
                <input type="hidden" name="courseId" value={c.id} />
                <button type="submit" class="btn-primary" style="padding:0.4rem 1rem">
                  📘 Compile manual ({items.filter((x) => x.inManual).length} included)
                </button>
                <span class="muted" style="font-size:0.83rem;margin-left:0.5rem">
                  Combines the "in manual" items, in this order, into one PDF for students.
                </span>
              </form>
            </>
          )}
        </div>
      );
    })
  }

  {courses.length === 0 && <p class="muted">No courses yet.</p>}

  <script>
    // Client-orchestrated "sub-agents": fire one short generation request per
    // module in parallel (bounded), with live progress — avoids the whole-course
    // single-request timeout. Each request returns JSON (format=json).
    type Mod = { id: string; title: string };

    async function generateAll(btn: HTMLButtonElement) {
      const course = btn.dataset.course!;
      const modules: Mod[] = JSON.parse(btn.dataset.modules || "[]");
      const progress = btn.parentElement?.querySelector(
        ".genall-progress",
      ) as HTMLElement | null;
      if (!modules.length) return;

      btn.disabled = true;
      let done = 0;
      let failed = 0;
      const total = modules.length;
      const update = () => {
        if (progress)
          progress.textContent = `Generating… ${done}/${total} done${
            failed ? ` · ${failed} failed` : ""
          }`;
      };
      update();

      let next = 0;
      const CONCURRENCY = 3;
      async function worker() {
        while (next < modules.length) {
          const m = modules[next++];
          const body = new FormData();
          body.set("courseId", course);
          body.set("type", "study_guide");
          body.set("scope_ref", `module:${m.id}`);
          body.set("format", "json");
          try {
            const res = await fetch("/api/admin/collateral/generate", {
              method: "POST",
              body,
            });
            const data = (await res
              .json()
              .catch(() => ({ ok: false }))) as { ok?: boolean };
            if (!data.ok) failed++;
          } catch {
            failed++;
          }
          done++;
          update();
        }
      }
      await Promise.all(
        Array.from({ length: Math.min(CONCURRENCY, modules.length) }, worker),
      );
      if (progress)
        progress.textContent = `Done — ${total - failed}/${total} generated${
          failed ? ` · ${failed} failed` : ""
        }. Reloading…`;
      setTimeout(() => location.reload(), 1400);
    }

    document
      .querySelectorAll<HTMLButtonElement>(".genall-btn")
      .forEach((btn) => btn.addEventListener("click", () => generateAll(btn)));
  </script>
</Layout>
