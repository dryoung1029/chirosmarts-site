---
import Layout from "@/layouts/Layout.astro";
import AdminNav from "@/components/AdminNav.astro";
import { getDb, schema } from "@/db/client";
import { sql, eq, desc } from "drizzle-orm";
import { formatPacific } from "@/lib/time";

const env = Astro.locals.runtime.env;
const db = getDb(env);
const flash = Astro.url.searchParams.get("done");

// Email config snapshot for the diagnostics panel.
const emailHasKey = !!env.RESEND_API_KEY;
const emailFrom = env.EMAIL_FROM || "onboarding@resend.dev (default sandbox)";
const emailReplyTo = env.EMAIL_REPLY_TO || "(none)";
const emailIsSandbox = /@resend\.dev/i.test(emailFrom) || !env.EMAIL_FROM;

// Stripe config snapshot (mode inferred from the key prefix; key never exposed).
const stripeHasKey = !!env.STRIPE_SECRET_KEY;
const stripeMode = env.STRIPE_SECRET_KEY?.startsWith("sk_live_")
  ? "live"
  : env.STRIPE_SECRET_KEY?.startsWith("sk_test_")
    ? "test"
    : null;
const stripeHasWebhook = !!env.STRIPE_WEBHOOK_SECRET;

const totalUsers = await db
  .select({ n: sql<number>`count(*)` })
  .from(schema.users)
  .get();
const activeEnrollments = await db
  .select({ n: sql<number>`count(*)` })
  .from(schema.enrollments)
  .where(eq(schema.enrollments.status, "active"))
  .get();
const completedEnrollments = await db
  .select({ n: sql<number>`count(*)` })
  .from(schema.enrollments)
  .where(eq(schema.enrollments.status, "completed"))
  .get();
const certsIssued = await db
  .select({ n: sql<number>`count(*)` })
  .from(schema.certificates)
  .where(eq(schema.certificates.status, "issued"))
  .get();

// Recent certificates (issued or otherwise) with the recipient email.
const recentCerts = await db
  .select({
    id: schema.certificates.id,
    certNumber: schema.certificates.certNumber,
    name: schema.certificates.legalNameSnapshot,
    course: schema.certificates.courseTitleSnapshot,
    status: schema.certificates.status,
    issuedAt: schema.certificates.issuedAt,
    userId: schema.certificates.userId,
  })
  .from(schema.certificates)
  .orderBy(desc(schema.certificates.createdAt))
  .limit(8)
  .all();

const stats = [
  { label: "Accounts", value: totalUsers?.n ?? 0 },
  { label: "Active enrollments", value: activeEnrollments?.n ?? 0 },
  { label: "Completed", value: completedEnrollments?.n ?? 0 },
  { label: "Certificates issued", value: certsIssued?.n ?? 0 },
];
---

<Layout title="Admin" showNav={true}>
  <AdminNav active="overview" />
  <h1>Admin overview</h1>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:1rem;margin:1.25rem 0">
    {
      stats.map((s) => (
        <div class="panel" style="margin:0;text-align:center">
          <div style="font-size:2rem;font-weight:700;color:var(--text)">{s.value}</div>
          <div class="muted" style="font-size:0.9rem">{s.label}</div>
        </div>
      ))
    }
  </div>

  <div class="panel">
    <h2>Recent certificates</h2>
    {
      recentCerts.length === 0 ? (
        <p style="margin:0">No certificates issued yet.</p>
      ) : (
        <table style="width:100%;border-collapse:collapse;font-size:0.92rem">
          <thead>
            <tr style="text-align:left;color:var(--muted)">
              <th style="padding:0.4rem 0.5rem">Number</th>
              <th style="padding:0.4rem 0.5rem">Recipient</th>
              <th style="padding:0.4rem 0.5rem">Issued</th>
              <th style="padding:0.4rem 0.5rem">Status</th>
            </tr>
          </thead>
          <tbody>
            {recentCerts.map((c) => (
              <tr style="border-top:1px solid var(--border)">
                <td style="padding:0.4rem 0.5rem"><code>{c.certNumber}</code></td>
                <td style="padding:0.4rem 0.5rem">
                  <a href={`/admin/students/${c.userId}`}>{c.name}</a>
                </td>
                <td style="padding:0.4rem 0.5rem">{formatPacific(c.issuedAt, { dateStyle: "medium" })}</td>
                <td style="padding:0.4rem 0.5rem">{c.status}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )
    }
  </div>

  <p class="muted" style="font-size:0.9rem">
    <a href="/admin/students">View all students →</a>
  </p>

  <div class="panel">
    <h2>Marketing</h2>
    {flash && <div class="notice ok">{flash}</div>}
    <p class="muted" style="margin-top:0;font-size:0.9rem">
      Push consented contacts (confirmed leads + opted-in users) to Brevo. No
      campaigns are sent — automations are configured in Brevo.
    </p>
    <form method="POST" action="/api/admin/brevo-sync" style="margin:0">
      <button type="submit">Sync to Brevo</button>
    </form>
  </div>

  <div class="panel">
    <h2>AI tutor — semantic index</h2>
    <p class="muted" style="margin-top:0;font-size:0.9rem">
      Embeds new transcript chunks so the tutor can answer by meaning, not just
      keywords. Run this after ingesting new transcripts. Already-embedded chunks
      are skipped.
    </p>
    <button type="button" id="embed-btn">Embed transcripts</button>
    <span id="embed-status" class="muted" style="margin-left:0.75rem"></span>
  </div>

  <div class="panel">
    <h2>Email diagnostics</h2>
    <p class="muted" style="margin-top:0;font-size:0.9rem">
      Whether transactional mail (sign-in links, receipts, certificates) can
      actually be delivered. Send a test and read Resend's real response.
    </p>
    <ul style="font-size:0.9rem;line-height:1.7;margin:0 0 0.75rem;padding-left:1.1rem">
      <li>API key (RESEND_API_KEY): <strong style={emailHasKey ? "color:var(--ok)" : "color:var(--warn)"}>{emailHasKey ? "set" : "NOT set — nothing will send"}</strong></li>
      <li>From (EMAIL_FROM): <code>{emailFrom}</code></li>
      <li>Reply-to (EMAIL_REPLY_TO): <code>{emailReplyTo}</code></li>
      {emailIsSandbox && (
        <li style="color:var(--warn)">
          Using Resend's sandbox domain — it only delivers to your own Resend
          account email; everyone else gets nothing. Verify a sending domain and
          set EMAIL_FROM to fix.
        </li>
      )}
    </ul>
    <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center">
      <input type="email" id="email-test-to" placeholder="you@example.com" style="flex:1 1 16rem;max-width:24rem" />
      <button type="button" id="email-test-btn">Send test email</button>
    </div>
    <p id="email-test-status" class="muted" style="font-size:0.85rem;margin:0.5rem 0 0;white-space:pre-wrap"></p>
  </div>

  <div class="panel">
    <h2>Payments (Stripe)</h2>
    <p class="muted" style="margin-top:0;font-size:0.9rem">
      Whether Checkout can take payments. Mode is inferred from the secret key prefix.
    </p>
    <ul style="font-size:0.9rem;line-height:1.7;margin:0;padding-left:1.1rem">
      <li>
        Secret key (STRIPE_SECRET_KEY):{" "}
        <strong style={stripeHasKey ? "color:var(--ok)" : "color:var(--warn)"}>
          {stripeHasKey ? `set — ${stripeMode ?? "unknown"} mode` : "NOT set — purchases are auto-comped (no charge)"}
        </strong>
      </li>
      <li>
        Webhook secret (STRIPE_WEBHOOK_SECRET):{" "}
        <strong style={stripeHasWebhook ? "color:var(--ok)" : "color:var(--warn)"}>
          {stripeHasWebhook ? "set" : "NOT set — payments won't fulfil enrollments"}
        </strong>
      </li>
      {stripeMode === "live" && (
        <li style="color:var(--warn)">Live mode — real cards will be charged.</li>
      )}
      {stripeHasKey && !stripeHasWebhook && (
        <li style="color:var(--warn)">
          Key set but no webhook secret — buyers pay but stay un-enrolled. Add the webhook endpoint and STRIPE_WEBHOOK_SECRET.
        </li>
      )}
    </ul>
  </div>

  <script is:inline>
    document.getElementById("email-test-btn").addEventListener("click", async () => {
      const btn = document.getElementById("email-test-btn");
      const status = document.getElementById("email-test-status");
      const to = document.getElementById("email-test-to").value.trim();
      if (!to) { status.textContent = "Enter an address first."; return; }
      btn.disabled = true;
      status.textContent = "Sending…";
      try {
        const res = await fetch("/api/admin/email-test", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ to }),
        });
        const d = await res.json();
        if (d.delivered) {
          status.textContent = `✓ Accepted by Resend (id ${d.id}). Check the inbox (and spam). From: ${d.from}`;
        } else {
          status.textContent = `✗ Not delivered. ${d.error || "Unknown error."}\nFrom: ${d.from} · API key: ${d.hasKey ? "set" : "NOT set"}`;
        }
      } catch (e) {
        status.textContent = "Network error sending the test.";
      } finally {
        btn.disabled = false;
      }
    });

    document.getElementById("embed-btn").addEventListener("click", async () => {
      const btn = document.getElementById("embed-btn");
      const status = document.getElementById("embed-status");
      btn.disabled = true;
      let total = 0;
      try {
        for (let i = 0; i < 100; i++) {
          status.textContent = "Embedding…";
          const res = await fetch("/api/admin/embed-transcripts", { method: "POST" });
          const data = await res.json();
          if (!data.ok) { status.textContent = data.message || "Error."; break; }
          total += data.embedded;
          status.textContent = `Embedded ${total}; ${data.remaining} remaining…`;
          if (data.remaining === 0) { status.textContent = `Done — ${total} chunk(s) embedded, index up to date.`; break; }
        }
      } catch {
        status.textContent = "Network error — re-run to continue (it resumes).";
      } finally {
        btn.disabled = false;
      }
    });
  </script>
</Layout>
