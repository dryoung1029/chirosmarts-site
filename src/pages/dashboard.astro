---
import Layout from "@/layouts/Layout.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import RoadmapList from "@/components/RoadmapList.astro";
import { getDb, schema } from "@/db/client";
import { eq } from "drizzle-orm";
import { getUserRoadmap } from "@/lib/roadmap";
import { getCaMembershipForUser, type CaMembership } from "@/lib/clinic";

const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;
const db = getDb(env);

// This is the STUDENT dashboard. Clinic-management content (the "Train Your CAs"
// roadmap + seat tools) lives on its own page (/clinic), so we drop the clinic
// roadmap here and show students only their own training paths.
const isClinicOwner = user.role === "clinic_admin";
const roadmap = (await getUserRoadmap(db, user.id)).filter(
  ({ template }) => template?.slug !== "oregon-clinic-owner",
);

// Courses the student is enrolled in (multi-course "Your courses" grid).
const myCourses = await db
  .select({
    slug: schema.courses.slug,
    title: schema.courses.title,
    creditHours: schema.courses.creditHours,
    status: schema.enrollments.status,
  })
  .from(schema.enrollments)
  .innerJoin(schema.courses, eq(schema.enrollments.courseId, schema.courses.id))
  .where(eq(schema.enrollments.userId, user.id))
  .all();
const activeCourses = myCourses.filter(
  (c) => c.status === "active" || c.status === "completed",
);

// Staff CAs (not owners) see which clinic they belong to.
const caMembership: CaMembership | null = isClinicOwner
  ? null
  : await getCaMembershipForUser(db, user.id);

const justTransferred = Astro.url.searchParams.get("transferred") === "1";
const readOnlyBlocked =
  Astro.url.searchParams.get("impersonation_readonly") === "1";

const months = [
  "", "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];
---

<Layout title="Your roadmap" showNav={true}>
  {justTransferred && (
    <div class="panel" style="border-color:var(--ok);color:var(--ok)">
      Clinic transferred. You're no longer the manager of that clinic.
    </div>
  )}
  {readOnlyBlocked && (
    <div class="panel" style="border-color:var(--warn);color:var(--warn)">
      That action is disabled while viewing as another user (read-only preview).
    </div>
  )}

  <h1>Welcome back, {user.displayName || user.legalName || "there"}</h1>
  <p>
    {user.birthMonth
      ? `Your CA renewal is keyed to your birth month (${months[user.birthMonth]}).`
      : "Your account is set up."}
  </p>

  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
      <h2 style="margin:0">Your courses</h2>
      <a href="/courses" style="font-size:0.9rem">Browse catalog →</a>
    </div>
    {
      activeCourses.length === 0 ? (
        <div style="margin:0.75rem 0 0;display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
          <Illustration name="empty-state" maxWidth={200} />
          <p class="muted" style="margin:0;flex:1;min-width:220px">
            You're not enrolled in any courses yet. <a href="/courses">Browse the catalog</a> to get started.
          </p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-top:0.75rem">
          {activeCourses.map((c) => (
            <a
              href={`/learn/${c.slug}`}
              class="panel"
              style="margin:0;text-decoration:none;display:flex;flex-direction:column;gap:0.35rem"
            >
              <span style="font-weight:600;color:var(--text)">{c.title}</span>
              <span class="muted" style="font-size:0.85rem">
                {c.creditHours} credit hour{c.creditHours === 1 ? "" : "s"} ·{" "}
                {c.status === "completed" ? "✓ Completed" : "In progress"}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  {
    isClinicOwner && (
      <a
        href="/clinic"
        class="panel"
        style="display:flex;align-items:center;justify-content:space-between;gap:1rem;text-decoration:none;border-color:var(--brand)"
      >
        <span class="muted" style="margin:0">
          Looking for clinic management? Buy seats and track your CAs on your
          <strong style="color:var(--text)"> clinic dashboard</strong>.
        </span>
        <span style="white-space:nowrap;color:var(--brand);font-weight:600">Clinic →</span>
      </a>
    )
  }

  {
    caMembership && (
      <div class="panel">
        <h2 style="margin:0">Your clinic</h2>
        <p style="margin:0.4rem 0 0">
          You're a CA at <strong style="color:var(--text)">{caMembership.clinic.name}</strong>.
          {activeCourses.length > 0
            ? " Your training is below — keep working through your roadmap."
            : " When your clinic assigns you a course seat, it'll appear above."}
        </p>
      </div>
    )
  }

  {
    roadmap.length === 0 && !isClinicOwner && (
      <div class="panel">
        <h2>No roadmap yet</h2>
        <p>You don't have an active roadmap. If this seems wrong, contact support.</p>
      </div>
    )
  }

  <RoadmapList roadmap={roadmap} />
</Layout>
