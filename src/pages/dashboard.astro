---
import Layout from "@/layouts/Layout.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import { getDb, schema } from "@/db/client";
import { eq } from "drizzle-orm";
import { getUserRoadmap } from "@/lib/roadmap";
import {
  getClinicForOwner,
  getCaMembershipForUser,
  type CaMembership,
} from "@/lib/clinic";
import { listPoolsDetailed } from "@/lib/seat-pools";

const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;
const db = getDb(env);
const roadmap = await getUserRoadmap(db, user.id);

// Courses the student is enrolled in (multi-course "Your courses" grid).
const myCourses = await db
  .select({
    slug: schema.courses.slug,
    title: schema.courses.title,
    creditHours: schema.courses.creditHours,
    status: schema.enrollments.status,
  })
  .from(schema.enrollments)
  .innerJoin(schema.courses, eq(schema.enrollments.courseId, schema.courses.id))
  .where(eq(schema.enrollments.userId, user.id))
  .all();
const activeCourses = myCourses.filter(
  (c) => c.status === "active" || c.status === "completed",
);

// Clinic owners get a callout linking to the dedicated clinic-management page
// (/clinic) where seats are bought and assigned. Seat usage shown for context.
let clinic = null;
let seatTotals: { purchased: number; available: number } | null = null;
if (user.role === "clinic_admin") {
  clinic = await getClinicForOwner(db, user.id);
  if (clinic) {
    const pools = await listPoolsDetailed(db, clinic.id);
    seatTotals = pools.reduce(
      (acc, p) => ({
        purchased: acc.purchased + p.summary.purchased,
        available: acc.available + p.summary.available,
      }),
      { purchased: 0, available: 0 },
    );
  }
}

// Staff CAs (not owners) see which clinic they belong to.
const caMembership: CaMembership | null = clinic
  ? null
  : await getCaMembershipForUser(db, user.id);

const justTransferred = Astro.url.searchParams.get("transferred") === "1";
const readOnlyBlocked =
  Astro.url.searchParams.get("impersonation_readonly") === "1";

const months = [
  "", "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

const statusLabel: Record<string, string> = {
  complete: "Done",
  available: "Up next",
  in_progress: "In progress",
  locked: "Locked",
  waived: "Waived",
};
const statusColor: Record<string, string> = {
  complete: "var(--ok)",
  available: "var(--accent)",
  in_progress: "var(--warn)",
  locked: "var(--muted)",
  waived: "var(--muted)",
};
---

<Layout title="Your roadmap" showNav={true}>
  {justTransferred && (
    <div class="panel" style="border-color:var(--ok);color:var(--ok)">
      Clinic transferred. You're no longer the manager of that clinic.
    </div>
  )}
  {readOnlyBlocked && (
    <div class="panel" style="border-color:var(--warn);color:var(--warn)">
      That action is disabled while viewing as another user (read-only preview).
    </div>
  )}

  <h1>Welcome back, {user.displayName || user.legalName || "there"}</h1>
  <p>
    {user.birthMonth
      ? `Your CA renewal is keyed to your birth month (${months[user.birthMonth]}).`
      : "Your account is set up."}
  </p>

  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
      <h2 style="margin:0">Your courses</h2>
      <a href="/courses" style="font-size:0.9rem">Browse catalog →</a>
    </div>
    {
      activeCourses.length === 0 ? (
        <div style="margin:0.75rem 0 0;display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
          <Illustration name="empty-state" maxWidth={200} />
          <p class="muted" style="margin:0;flex:1;min-width:220px">
            You're not enrolled in any courses yet. <a href="/courses">Browse the catalog</a> to get started.
          </p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-top:0.75rem">
          {activeCourses.map((c) => (
            <a
              href={`/learn/${c.slug}`}
              class="panel"
              style="margin:0;text-decoration:none;display:flex;flex-direction:column;gap:0.35rem"
            >
              <span style="font-weight:600;color:var(--text)">{c.title}</span>
              <span class="muted" style="font-size:0.85rem">
                {c.creditHours} credit hour{c.creditHours === 1 ? "" : "s"} ·{" "}
                {c.status === "completed" ? "✓ Completed" : "In progress"}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  {
    clinic && (
      <div class="panel" style="border-color:var(--brand);background:var(--brand-tint, var(--surface))">
        <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
          <div style="flex:1;min-width:240px">
            <h2 style="margin:0 0 0.35rem">{clinic.name}</h2>
            <p style="margin:0">
              {seatTotals && seatTotals.purchased > 0
                ? `${seatTotals.available} of ${seatTotals.purchased} training seats available. Buy more or assign CAs from your clinic page.`
                : "Buy a pool of training seats and assign them to your Chiropractic Assistants."}
            </p>
          </div>
          <a class="btn" href="/clinic" style="white-space:nowrap;margin:0">
            Manage clinic →
          </a>
        </div>
      </div>
    )
  }

  {
    caMembership && (
      <div class="panel">
        <h2 style="margin:0">Your clinic</h2>
        <p style="margin:0.4rem 0 0">
          You're a CA at <strong style="color:var(--text)">{caMembership.clinic.name}</strong>.
          {activeCourses.length > 0
            ? " Your training is below — keep working through your roadmap."
            : " When your clinic assigns you a course seat, it'll appear above."}
        </p>
      </div>
    )
  }

  {
    roadmap.length === 0 && !clinic && (
      <div class="panel">
        <h2>No roadmap yet</h2>
        <p>You don't have an active roadmap. If this seems wrong, contact support.</p>
      </div>
    )
  }

  {
    roadmap.map(({ template, steps }) => (
      <div class="panel">
        <h2>{template?.name ?? "Roadmap"}</h2>
        {template?.description && <p style="margin-top:0">{template.description}</p>}
        <ol style="list-style:none;padding:0;margin:0.5rem 0 0">
          {steps.map((s) => (
            <li
              style="display:flex;align-items:center;gap:0.75rem;padding:0.7rem 0;border-top:1px solid var(--border)"
            >
              <span
                aria-hidden="true"
                style={`flex:0 0 auto;width:1.4rem;height:1.4rem;border-radius:50%;display:grid;place-items:center;font-size:0.8rem;border:2px solid ${statusColor[s.status]};color:${statusColor[s.status]}`}
              >
                {s.status === "complete" ? "✓" : s.position}
              </span>
              <span style="flex:1">
                {s.href ? <a href={s.href}>{s.title}</a> : s.title}
              </span>
              <span
                style={`font-size:0.8rem;color:${statusColor[s.status]}`}
              >
                {s.href && s.status !== "complete" ? (
                  <a href={s.href} style={`color:${statusColor[s.status]}`}>
                    {statusLabel[s.status] ?? s.status} →
                  </a>
                ) : (
                  statusLabel[s.status] ?? s.status
                )}
              </span>
            </li>
          ))}
        </ol>
      </div>
    ))
  }

</Layout>
