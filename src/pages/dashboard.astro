---
import Layout from "@/layouts/Layout.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import { getDb, schema } from "@/db/client";
import { eq } from "drizzle-orm";
import { getUserRoadmap } from "@/lib/roadmap";
import { getClinicForOwner } from "@/lib/clinic";
import { listPoolsDetailed, type PoolView } from "@/lib/seat-pools";

const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;
const db = getDb(env);
const roadmap = await getUserRoadmap(db, user.id);

// Courses the student is enrolled in (multi-course "Your courses" grid).
const myCourses = await db
  .select({
    slug: schema.courses.slug,
    title: schema.courses.title,
    creditHours: schema.courses.creditHours,
    status: schema.enrollments.status,
  })
  .from(schema.enrollments)
  .innerJoin(schema.courses, eq(schema.enrollments.courseId, schema.courses.id))
  .where(eq(schema.enrollments.userId, user.id))
  .all();
const activeCourses = myCourses.filter(
  (c) => c.status === "active" || c.status === "completed",
);

// Clinic-owner management data (only for clinic_admin accounts).
const params = Astro.url.searchParams;
const q = {
  error: params.get("error"),
  assigned: params.get("assigned"),
  dev: params.get("dev"),
  seats: params.get("seats"),
};
let clinic = null;
let pools: PoolView[] = [];
// Courses a clinic can buy seats for: published, standalone (non-bundle) courses.
// Bundles enroll their CHILDREN, so a per-bundle seat pool wouldn't grant access.
let purchasableCourses: { id: string; title: string; priceCents: number }[] = [];
if (user.role === "clinic_admin") {
  clinic = await getClinicForOwner(db, user.id);
  if (clinic) {
    pools = await listPoolsDetailed(db, clinic.id);
    const bundleIds = (
      await db
        .select({ id: schema.bundleItems.bundleCourseId })
        .from(schema.bundleItems)
        .all()
    ).map((b) => b.id);
    const published = await db
      .select({
        id: schema.courses.id,
        title: schema.courses.title,
        priceCents: schema.courses.priceCents,
      })
      .from(schema.courses)
      .where(eq(schema.courses.status, "published"))
      .all();
    purchasableCourses = published.filter((c) => !bundleIds.includes(c.id));
  }
}

const dollars = (cents: number) =>
  `$${(cents / 100).toLocaleString("en-US", { minimumFractionDigits: cents % 100 ? 2 : 0, maximumFractionDigits: 2 })}`;

const assignmentStatusLabel: Record<string, string> = {
  invited: "Invited",
  active: "Joined",
  expired: "Expired",
  revoked: "Revoked",
};

const months = [
  "", "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

const statusLabel: Record<string, string> = {
  complete: "Done",
  available: "Up next",
  in_progress: "In progress",
  locked: "Locked",
  waived: "Waived",
};
const statusColor: Record<string, string> = {
  complete: "var(--ok)",
  available: "var(--accent)",
  in_progress: "var(--warn)",
  locked: "var(--muted)",
  waived: "var(--muted)",
};
---

<Layout title="Your roadmap" showNav={true}>
  <h1>Welcome back, {user.displayName || user.legalName || "there"}</h1>
  <p>
    {user.birthMonth
      ? `Your CA renewal is keyed to your birth month (${months[user.birthMonth]}).`
      : "Your account is set up."}
  </p>

  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
      <h2 style="margin:0">Your courses</h2>
      <a href="/courses" style="font-size:0.9rem">Browse catalog →</a>
    </div>
    {
      activeCourses.length === 0 ? (
        <div style="margin:0.75rem 0 0;display:flex;gap:1rem;align-items:center;flex-wrap:wrap">
          <Illustration name="empty-state" maxWidth={200} />
          <p class="muted" style="margin:0;flex:1;min-width:220px">
            You're not enrolled in any courses yet. <a href="/courses">Browse the catalog</a> to get started.
          </p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-top:0.75rem">
          {activeCourses.map((c) => (
            <a
              href={`/learn/${c.slug}`}
              class="panel"
              style="margin:0;text-decoration:none;display:flex;flex-direction:column;gap:0.35rem"
            >
              <span style="font-weight:600;color:var(--text)">{c.title}</span>
              <span class="muted" style="font-size:0.85rem">
                {c.creditHours} credit hour{c.creditHours === 1 ? "" : "s"} ·{" "}
                {c.status === "completed" ? "✓ Completed" : "In progress"}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  {
    clinic && (
      <div class="panel">
        <h2>{clinic.name} — manage course seats</h2>

        {q.error && <div class="notice err">{q.error}</div>}
        {q.assigned === "invited" && (
          <div class="notice ok">Invite sent. The CA will get an email to claim their seat.</div>
        )}
        {q.assigned === "active" && (
          <div class="notice ok">Seat granted — that CA now has access to the course.</div>
        )}
        {q.seats && (
          <div class="notice ok">
            Added {q.seats} seat{q.seats === "1" ? "" : "s"} to the pool (test mode — no charge).
          </div>
        )}
        {q.dev && (
          <div class="notice warn">
            Dev mode (no email key set). Claim link:{" "}
            <a href={q.dev}>{q.dev}</a>
          </div>
        )}

        {/* Buy seats for a course — opens (or adds to) that course's pool. */}
        <form method="POST" action="/api/clinic/seats" style="margin-top:0.5rem">
          <label for="buy-course">Buy training seats</label>
          <div class="row" style="flex-wrap:wrap">
            <select id="buy-course" name="courseId" style="flex:2;min-width:200px">
              {purchasableCourses.length === 0 ? (
                <option value="">No purchasable courses</option>
              ) : (
                purchasableCourses.map((c) => (
                  <option value={c.id}>
                    {c.title} — {dollars(c.priceCents)}/seat
                  </option>
                ))
              )}
            </select>
            <input
              type="text"
              name="count"
              inputmode="numeric"
              placeholder="Qty"
              style="flex:0 0 5rem"
            />
            <button type="submit" style="margin-top:0;white-space:nowrap">
              Add seats
            </button>
          </div>
          <p class="muted" style="margin:0.4rem 0 0">
            Each seat lets you grant one CA access to that course. Test mode: seats
            are comped instantly (Stripe checkout when keys are set).
          </p>
        </form>

        {pools.length === 0 ? (
          <p class="muted" style="margin-top:1.25rem">
            No seat pools yet. Buy seats for a course above to get started.
          </p>
        ) : (
          pools.map((p) => {
            const visible = p.assignments.filter(
              (a) =>
                a.assignment.status === "invited" ||
                a.assignment.status === "active",
            );
            return (
              <div
                style="margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border)"
              >
                <div style="display:flex;align-items:baseline;justify-content:space-between;gap:1rem;flex-wrap:wrap">
                  <h3 style="margin:0">{p.courseTitle}</h3>
                  <span class="muted" style="font-size:0.9rem">
                    <strong style="color:var(--text)">{p.summary.available}</strong> available
                    of {p.summary.purchased} ({p.summary.consumed} in use)
                  </span>
                </div>

                <form
                  method="POST"
                  action="/api/clinic/assign"
                  style="margin-top:0.75rem"
                >
                  <input type="hidden" name="courseId" value={p.courseId} />
                  <div class="row">
                    <input
                      type="email"
                      name="email"
                      placeholder="ca@example.com"
                      disabled={p.summary.available < 1}
                      style="flex:1"
                    />
                    <button
                      type="submit"
                      disabled={p.summary.available < 1}
                      style="margin-top:0;white-space:nowrap"
                    >
                      Assign seat
                    </button>
                  </div>
                  {p.summary.available < 1 && (
                    <p class="muted" style="margin:0.4rem 0 0">
                      No seats available — buy more above to assign another CA.
                    </p>
                  )}
                </form>

                {visible.length === 0 ? (
                  <p class="muted" style="margin:0.6rem 0 0">
                    No CAs assigned to this course yet.
                  </p>
                ) : (
                  <ol style="list-style:none;padding:0;margin:0.5rem 0 0">
                    {visible.map((r) => (
                      <li style="display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0;border-top:1px solid var(--border)">
                        <span style="flex:1">
                          <span style="color:var(--text)">{r.legalName || r.email}</span>
                          {r.legalName && <span class="muted"> · {r.email}</span>}
                          <br />
                          <span class="muted">
                            {r.assignment.status === "active"
                              ? r.intakeCompletedAt
                                ? "Onboarded — in training"
                                : "Joined — finishing intake"
                              : "Invited — not claimed yet"}
                          </span>
                        </span>
                        <span
                          style={`font-size:0.8rem;color:${r.assignment.status === "active" ? "var(--ok)" : "var(--warn)"}`}
                        >
                          {assignmentStatusLabel[r.assignment.status]}
                        </span>
                        {r.assignment.status === "invited" && (
                          <form method="POST" action="/api/clinic/revoke" style="margin:0">
                            <input type="hidden" name="assignmentId" value={r.assignment.id} />
                            <button class="link" type="submit" style="color:var(--muted)">
                              Revoke
                            </button>
                          </form>
                        )}
                      </li>
                    ))}
                  </ol>
                )}
              </div>
            );
          })
        )}
      </div>
    )
  }

  {
    roadmap.length === 0 && !clinic && (
      <div class="panel">
        <h2>No roadmap yet</h2>
        <p>You don't have an active roadmap. If this seems wrong, contact support.</p>
      </div>
    )
  }

  {
    roadmap.map(({ template, steps }) => (
      <div class="panel">
        <h2>{template?.name ?? "Roadmap"}</h2>
        {template?.description && <p style="margin-top:0">{template.description}</p>}
        <ol style="list-style:none;padding:0;margin:0.5rem 0 0">
          {steps.map((s) => (
            <li
              style="display:flex;align-items:center;gap:0.75rem;padding:0.7rem 0;border-top:1px solid var(--border)"
            >
              <span
                aria-hidden="true"
                style={`flex:0 0 auto;width:1.4rem;height:1.4rem;border-radius:50%;display:grid;place-items:center;font-size:0.8rem;border:2px solid ${statusColor[s.status]};color:${statusColor[s.status]}`}
              >
                {s.status === "complete" ? "✓" : s.position}
              </span>
              <span style="flex:1">
                {s.href ? <a href={s.href}>{s.title}</a> : s.title}
              </span>
              <span
                style={`font-size:0.8rem;color:${statusColor[s.status]}`}
              >
                {s.href && s.status !== "complete" ? (
                  <a href={s.href} style={`color:${statusColor[s.status]}`}>
                    {statusLabel[s.status] ?? s.status} →
                  </a>
                ) : (
                  statusLabel[s.status] ?? s.status
                )}
              </span>
            </li>
          ))}
        </ol>
      </div>
    ))
  }

  <p class="muted">
    More is coming: your course player and progress tracking arrive in the next
    build (M2).
  </p>
</Layout>
