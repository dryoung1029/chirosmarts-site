---
import Layout from "@/layouts/Layout.astro";
import { getDb, schema } from "@/db/client";
import { eq } from "drizzle-orm";
import { getUserRoadmap } from "@/lib/roadmap";
import {
  getClinicForOwner,
  getSeatSummary,
  getRosterDetailed,
  type SeatSummary,
  type RosterEntry,
} from "@/lib/clinic";

const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;
const db = getDb(env);
const roadmap = await getUserRoadmap(db, user.id);

// Courses the student is enrolled in (multi-course "Your courses" grid).
const myCourses = await db
  .select({
    slug: schema.courses.slug,
    title: schema.courses.title,
    creditHours: schema.courses.creditHours,
    status: schema.enrollments.status,
  })
  .from(schema.enrollments)
  .innerJoin(schema.courses, eq(schema.enrollments.courseId, schema.courses.id))
  .where(eq(schema.enrollments.userId, user.id))
  .all();
const activeCourses = myCourses.filter(
  (c) => c.status === "active" || c.status === "completed",
);

// Clinic-owner management data (only for clinic_admin accounts).
const params = Astro.url.searchParams;
const q = {
  error: params.get("error"),
  invited: params.get("invited"),
  dev: params.get("dev"),
  seats: params.get("seats"),
};
let clinic = null;
let seats: SeatSummary | null = null;
let roster: RosterEntry[] = [];
if (user.role === "clinic_admin") {
  clinic = await getClinicForOwner(db, user.id);
  if (clinic) {
    seats = await getSeatSummary(db, clinic);
    roster = await getRosterDetailed(db, clinic.id);
  }
}

const memberStatusLabel: Record<string, string> = {
  invited: "Invited",
  active: "Joined",
  removed: "Removed",
};

const months = [
  "", "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December",
];

const statusLabel: Record<string, string> = {
  complete: "Done",
  available: "Up next",
  in_progress: "In progress",
  locked: "Locked",
  waived: "Waived",
};
const statusColor: Record<string, string> = {
  complete: "var(--ok)",
  available: "var(--accent)",
  in_progress: "var(--warn)",
  locked: "var(--muted)",
  waived: "var(--muted)",
};
---

<Layout title="Your roadmap" showNav={true}>
  <h1>Welcome back, {user.displayName || user.legalName || "there"}</h1>
  <p>
    {user.birthMonth
      ? `Your CA renewal is keyed to your birth month (${months[user.birthMonth]}).`
      : "Your account is set up."}
  </p>

  <div class="panel">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap">
      <h2 style="margin:0">Your courses</h2>
      <a href="/courses" style="font-size:0.9rem">Browse catalog →</a>
    </div>
    {
      activeCourses.length === 0 ? (
        <p class="muted" style="margin:0.75rem 0 0">
          You're not enrolled in any courses yet. <a href="/courses">Browse the catalog</a> to get started.
        </p>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.75rem;margin-top:0.75rem">
          {activeCourses.map((c) => (
            <a
              href={`/learn/${c.slug}`}
              class="panel"
              style="margin:0;text-decoration:none;display:flex;flex-direction:column;gap:0.35rem"
            >
              <span style="font-weight:600;color:var(--text)">{c.title}</span>
              <span class="muted" style="font-size:0.85rem">
                {c.creditHours} credit hour{c.creditHours === 1 ? "" : "s"} ·{" "}
                {c.status === "completed" ? "✓ Completed" : "In progress"}
              </span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  {
    clinic && seats && (
      <div class="panel">
        <h2>{clinic.name} — manage your CAs</h2>

        {q.error && <div class="notice err">{q.error}</div>}
        {q.invited && (
          <div class="notice ok">Invite sent. The CA will get an email to claim their seat.</div>
        )}
        {q.seats && (
          <div class="notice ok">
            Added {q.seats} seat{q.seats === "1" ? "" : "s"} to your pool (test mode — no charge).
          </div>
        )}
        {q.dev && (
          <div class="notice warn">
            Dev mode (no email key set). Claim link:{" "}
            <a href={q.dev}>{q.dev}</a>
          </div>
        )}

        <p style="margin-top:0">
          Seats: <strong style="color:var(--text)">{seats.available}</strong> available
          of {seats.purchased} purchased ({seats.consumed} in use).
        </p>

        <div class="row" style="align-items:flex-end">
          <form method="POST" action="/api/clinic/seats" style="flex:1">
            <label for="count">Buy training seats</label>
            <div class="row">
              <input id="count" type="text" name="count" inputmode="numeric" placeholder="e.g. 5" />
              <button type="submit" style="margin-top:0;white-space:nowrap">Add seats</button>
            </div>
            <p class="muted" style="margin:0.4rem 0 0">
              Test mode: seats are comped instantly. Stripe checkout arrives in M3.
            </p>
          </form>
        </div>

        <form method="POST" action="/api/clinic/invite" style="margin-top:1.25rem">
          <label for="email">Invite a CA by email</label>
          <div class="row">
            <input
              id="email"
              type="email"
              name="email"
              placeholder="ca@example.com"
              disabled={seats.available < 1}
            />
            <button type="submit" disabled={seats.available < 1} style="margin-top:0;white-space:nowrap">
              Send invite
            </button>
          </div>
          {seats.available < 1 && (
            <p class="muted" style="margin:0.4rem 0 0">
              No seats available — buy more above to invite another CA.
            </p>
          )}
        </form>

        <h2 style="margin-top:1.5rem">Your CAs ({roster.filter((r) => r.member.status !== "removed").length})</h2>
        {roster.filter((r) => r.member.status !== "removed").length === 0 ? (
          <p style="margin-top:0">No CAs yet. Invite your first one above.</p>
        ) : (
          <ol style="list-style:none;padding:0;margin:0.5rem 0 0">
            {roster
              .filter((r) => r.member.status !== "removed")
              .map((r) => (
                <li style="display:flex;align-items:center;gap:0.75rem;padding:0.7rem 0;border-top:1px solid var(--border)">
                  <span style="flex:1">
                    <span style="color:var(--text)">{r.legalName || r.member.email}</span>
                    {r.legalName && <span class="muted"> · {r.member.email}</span>}
                    <br />
                    <span class="muted">
                      {r.member.status === "active"
                        ? r.intakeCompletedAt
                          ? "Onboarded — in training"
                          : "Joined — finishing intake"
                        : "Invited — not joined yet"}
                    </span>
                  </span>
                  <span style={`font-size:0.8rem;color:${r.member.status === "active" ? "var(--ok)" : "var(--warn)"}`}>
                    {memberStatusLabel[r.member.status]}
                  </span>
                  {r.member.status === "invited" && (
                    <form method="POST" action="/api/clinic/revoke" style="margin:0">
                      <input type="hidden" name="memberId" value={r.member.id} />
                      <button class="link" type="submit" style="color:var(--muted)">
                        Revoke
                      </button>
                    </form>
                  )}
                </li>
              ))}
          </ol>
        )}
      </div>
    )
  }

  {
    roadmap.length === 0 && !clinic && (
      <div class="panel">
        <h2>No roadmap yet</h2>
        <p>You don't have an active roadmap. If this seems wrong, contact support.</p>
      </div>
    )
  }

  {
    roadmap.map(({ template, steps }) => (
      <div class="panel">
        <h2>{template?.name ?? "Roadmap"}</h2>
        {template?.description && <p style="margin-top:0">{template.description}</p>}
        <ol style="list-style:none;padding:0;margin:0.5rem 0 0">
          {steps.map((s) => (
            <li
              style="display:flex;align-items:center;gap:0.75rem;padding:0.7rem 0;border-top:1px solid var(--border)"
            >
              <span
                aria-hidden="true"
                style={`flex:0 0 auto;width:1.4rem;height:1.4rem;border-radius:50%;display:grid;place-items:center;font-size:0.8rem;border:2px solid ${statusColor[s.status]};color:${statusColor[s.status]}`}
              >
                {s.status === "complete" ? "✓" : s.position}
              </span>
              <span style="flex:1">
                {s.href ? <a href={s.href}>{s.title}</a> : s.title}
              </span>
              <span
                style={`font-size:0.8rem;color:${statusColor[s.status]}`}
              >
                {s.href && s.status !== "complete" ? (
                  <a href={s.href} style={`color:${statusColor[s.status]}`}>
                    {statusLabel[s.status] ?? s.status} →
                  </a>
                ) : (
                  statusLabel[s.status] ?? s.status
                )}
              </span>
            </li>
          ))}
        </ol>
      </div>
    ))
  }

  <p class="muted">
    More is coming: your course player and progress tracking arrive in the next
    build (M2).
  </p>
</Layout>
