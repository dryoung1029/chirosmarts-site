---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import Illustration from "@/components/marketing/Illustration.astro";
---

<MarketingLayout
  title="Page not found"
  description="That page doesn't exist. Find Oregon CA training, renewal, and certificate verification on ChiroSmarts."
  canonicalPath="/404"
>
  <section class="mk-section" style="text-align:center;padding-top:3.5rem">
    <div class="mk-container" style="max-width:560px">
      <Illustration
        name="error-404"
        maxWidth={420}
        sizes="(max-width: 600px) 88vw, 420px"
        loading="eager"
        style="margin:0 auto 1.5rem"
      />
      <h1 style="font-size:1.9rem;margin:0 0 0.5rem">We can't find that page</h1>
      <p style="color:var(--muted);margin:0 0 1.5rem">
        The link may be broken or the page may have moved. Here's where most people are headed:
      </p>
      <div style="display:flex;gap:0.75rem;flex-wrap:wrap;justify-content:center">
        <a class="btn-primary" href="/">Home</a>
        <a class="btn-secondary" href="/courses">Browse courses</a>
        <a class="btn-secondary" href="/verify">Verify a certificate</a>
      </div>
    </div>
  </section>
</MarketingLayout>
