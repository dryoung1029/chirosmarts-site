---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { getDb } from "@/db/client";
import { confirmLead } from "@/lib/leads";
import { syncLeadToBrevo } from "@/lib/brevo";

const env = Astro.locals.runtime.env;
const db = getDb(env);
const token = Astro.url.searchParams.get("token") ?? "";
const lead = await confirmLead(db, token);
const isChecklist = lead?.source === "checklist_pdf";
const isNewsletter = lead?.source === "newsletter";

// Newsletter subscribers AND free-checklist downloaders land in Brevo
// immediately on confirm (real-time list loading — both go to the newsletter
// list, tagged by SOURCE); other sources sync via the admin batch. The form
// discloses ongoing email + unsubscribe, so this matches what they agreed to.
// Best-effort — never blocks the confirmation / download.
if (lead && (isNewsletter || isChecklist)) {
  try {
    await syncLeadToBrevo(env, db, {
      id: lead.id,
      email: lead.email,
      source: lead.source,
      birthMonth: lead.birthMonth,
    });
  } catch {
    /* admin batch sync will pick it up */
  }
}
---

<MarketingLayout
  title="Email confirmed"
  description="Confirm your ChiroSmarts email."
  canonicalPath="/leads/confirm"
>
  <section class="mk-section" style="padding-top:3rem">
    <div class="mk-container" style="max-width:640px;text-align:center">
      {
        !lead ? (
          <>
            <h1>That link didn't work</h1>
            <p style="color:var(--muted)">
              The confirmation link is invalid or has already been used. You can
              request it again from the page where you signed up.
            </p>
          </>
        ) : (
          <>
            <h1>You're confirmed ✓</h1>
            {isChecklist ? (
              <>
                <p style="color:var(--muted)">Your Oregon CA certification checklist is ready.</p>
                <a class="btn-primary" href={`/api/leads/asset?lid=${lead.id}`}>Download the checklist (PDF)</a>
              </>
            ) : isNewsletter ? (
              <p style="color:var(--muted)">
                You're subscribed to the ChiroSmarts newsletter — practical tips for
                Oregon chiropractic assistants. You can unsubscribe anytime from any
                email we send.
              </p>
            ) : (
              <p style="color:var(--muted)">
                We'll remind you before your Oregon CA renewal deadline. You can
                unsubscribe anytime from any email we send.
              </p>
            )}
            <p style="margin-top:1.5rem"><a href="/courses">Browse courses →</a></p>
          </>
        )
      }
    </div>
  </section>
</MarketingLayout>
