---
// Public landing for certificate verification: enter a code → /verify/<code>.
import Layout from "@/layouts/Layout.astro";
import Logo from "@/components/Logo.astro";

const code = Astro.url.searchParams.get("code")?.trim();
if (code) return Astro.redirect(`/verify/${encodeURIComponent(code.toUpperCase())}`);
---

<Layout title="Verify a certificate">
  <div style="display:flex;justify-content:center;margin:0.5rem 0 1.5rem">
    <Logo height={38} />
  </div>
  <div class="panel">
    <h1>Verify a certificate</h1>
    <p>
      Enter the verification code printed on a ChiroSmarts certificate (or scan
      its QR code) to confirm it's genuine.
    </p>
    <form method="get" action="/verify">
      <label for="code">Verification code</label>
      <input
        type="text"
        id="code"
        name="code"
        placeholder="e.g. K7M2QP9XTR"
        autocomplete="off"
        autocapitalize="characters"
        required
      />
      <button type="submit">Verify</button>
    </form>
  </div>
</Layout>
