---
// Public certificate verification. No auth — anyone with the code can confirm
// authenticity. Snapshotted values are read straight off the certificate row.
import Layout from "@/layouts/Layout.astro";
import Logo from "@/components/Logo.astro";
import { getDb } from "@/db/client";
import { getCertificateByCode } from "@/lib/certificate";
import { formatPacific } from "@/lib/time";

const code = (Astro.params.code ?? "").toUpperCase();
const db = getDb(Astro.locals.runtime.env);
const cert = await getCertificateByCode(db, code);
const valid = cert && cert.status === "issued";
const revoked = cert && cert.status === "revoked";
const superseded = cert && cert.status === "reissued";

const fmtCredits = (h: number) =>
  `${Number.isInteger(h) ? h : h.toFixed(1)} ${h === 1 ? "hour" : "hours"}`;
---

<Layout title="Verify certificate">
  <div style="display:flex;justify-content:center;margin:0.5rem 0 1.5rem">
    <Logo height={38} />
  </div>

  {
    valid && cert && (
      <div class="panel" style="border-color:var(--success)">
        <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem">
          <span style="font-size:1.5rem">✓</span>
          <h1 style="margin:0;color:var(--success)">Valid certificate</h1>
        </div>
        <p style="color:var(--muted);margin-top:0">
          This is a genuine ChiroSmarts certificate of completion.
        </p>
        <dl style="display:grid;grid-template-columns:auto 1fr;gap:0.5rem 1.25rem;margin:1rem 0 0">
          <dt class="muted">Recipient</dt>
          <dd style="margin:0;color:var(--text)"><strong>{cert.legalNameSnapshot}</strong></dd>
          <dt class="muted">Course</dt>
          <dd style="margin:0;color:var(--text)">{cert.courseTitleSnapshot}</dd>
          <dt class="muted">Credit</dt>
          <dd style="margin:0;color:var(--text)">{fmtCredits(cert.creditHoursSnapshot)}</dd>
          <dt class="muted">Completed</dt>
          <dd style="margin:0;color:var(--text)">{formatPacific(cert.issuedAt, { dateStyle: "long" })}</dd>
          <dt class="muted">Instructor</dt>
          <dd style="margin:0;color:var(--text)">{cert.instructorSnapshot}</dd>
          <dt class="muted">Certificate No.</dt>
          <dd style="margin:0;color:var(--text)">{cert.certNumber}</dd>
        </dl>
        <p style="margin-top:1.25rem">
          <a class="btn" href={`/certificate/${cert.verificationCode}.pdf`}>Download PDF</a>
        </p>
      </div>
    )
  }

  {
    revoked && cert && (
      <div class="panel" style="border-color:var(--danger)">
        <h1 style="margin:0;color:var(--danger)">⚠ Certificate revoked</h1>
        <p>
          Certificate <strong>{cert.certNumber}</strong> was issued but has since
          been revoked and is no longer valid. Contact ChiroSmarts if you believe
          this is in error.
        </p>
      </div>
    )
  }

  {
    superseded && cert && (
      <div class="panel" style="border-color:var(--warn)">
        <h1 style="margin:0;color:var(--warn)">⚠ Superseded certificate</h1>
        <p>
          Certificate <strong>{cert.certNumber}</strong> was reissued and this
          copy is no longer the current one. The replacement certificate is the
          valid record. Contact ChiroSmarts for the current verification code.
        </p>
      </div>
    )
  }

  {
    !cert && (
      <div class="panel">
        <h1 style="margin:0">Certificate not found</h1>
        <p>
          No certificate matches the code <strong>{code || "(none)"}</strong>.
          Check the code and try again.
        </p>
        <p><a href="/verify">Enter a different code</a></p>
      </div>
    )
  }
</Layout>
