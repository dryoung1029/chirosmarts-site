---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import Illustration from "@/components/marketing/Illustration.astro";
import { getEntry, render } from "astro:content";
import { getDb } from "@/db/client";
import { getCourseBySlug } from "@/lib/courses";
import { getSiteUrl } from "@/lib/env";
import { articleLd, personLd } from "@/lib/structured-data";
import { OWNER, ownerCopy } from "@/config/marketing";

const env = Astro.locals.runtime.env;
const { slug } = Astro.params;
const entry = await getEntry("guides", slug!);
if (!entry) return Astro.redirect("/courses", 302);

const { Content, headings } = await render(entry);
const toc = headings.filter((h) => h.depth === 2);

const author = entry.data.author ?? OWNER.instructor.name ?? null;
const siteUrl = getSiteUrl(env).replace(/\/$/, "");

let related = null;
if (entry.data.relatedCourse) {
  const db = getDb(env);
  related = await getCourseBySlug(db, entry.data.relatedCourse);
}

const ld = articleLd({
  title: entry.data.title,
  description: entry.data.description,
  url: `${siteUrl}/guides/${slug}`,
  authorName: author ?? undefined,
  datePublished: entry.data.lastUpdated.includes("[") ? undefined : entry.data.lastUpdated,
  siteUrl,
});
const usd = (c: number) => `$${(c / 100).toFixed(0)}`;
---

<MarketingLayout
  title={entry.data.title}
  description={entry.data.description}
  canonicalPath={`/guides/${slug}`}
  jsonLd={[ld, personLd(siteUrl)]}
>
  <section class="mk-section" style="padding-top:2.5rem">
    <div class="mk-container guide-wrap" style="display:grid;grid-template-columns:220px 1fr;gap:2rem;align-items:start">
      <!-- Table of contents -->
      <nav class="guide-toc" aria-label="On this page" style="position:sticky;top:1rem">
        <p style="color:var(--muted);font-size:0.8rem;text-transform:uppercase;letter-spacing:0.05em">On this page</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem">
          {toc.map((h) => (
            <li><a href={`#${h.slug}`} style="color:var(--muted);text-decoration:none;font-size:0.9rem">{h.text}</a></li>
          ))}
        </ul>
      </nav>

      <article style="max-width:720px;line-height:1.7">
        <Illustration name="oregon-path" maxWidth={720} sizes="(max-width: 800px) 92vw, 720px" style="margin:0 0 1.25rem" />
        <h1 style="margin:0 0 0.5rem">{entry.data.title}</h1>
        <p style="color:var(--muted);margin:0 0 1.5rem;font-size:0.9rem">
          By {author ? author : <span class="owner-copy">{ownerCopy("author name")}</span>}
          {entry.data.authorCredentials && `, ${entry.data.authorCredentials}`}
          · Last updated: {entry.data.lastUpdated}
        </p>

        <div class="guide-body">
          <Content />
        </div>

        {related && (
          <div class="mk-card" style="margin-top:2rem">
            <strong style="color:var(--text)">Related course: {related.title}</strong>
            <p style="margin:0.3rem 0 0.6rem;color:var(--muted)">{related.creditHours} credit hours · {usd(related.priceCents)}</p>
            <a class="btn-primary" href={`/courses/${related.slug}`}>View course →</a>
          </div>
        )}
      </article>
    </div>
  </section>

  <style>
    .guide-body :global(h2) { scroll-margin-top: 1rem; margin-top: 2rem; }
    @media (max-width: 800px) {
      .guide-toc { display: none; }
      .guide-wrap { grid-template-columns: 1fr !important; }
    }
  </style>
</MarketingLayout>
