---
import Layout from "@/layouts/Layout.astro";
import { getDb } from "@/db/client";
import { getCourseBySlug, getCourseStructure } from "@/lib/courses";
import { hasActiveEnrollment } from "@/lib/entitlement";
import { getCourseSeatTime } from "@/lib/progress";
import { getModuleQuiz, getFinalExam, hasPassed } from "@/lib/quiz";
import { getActiveCertificate, issueAndEmailCertificate } from "@/lib/certificate";
import { listCourseResources } from "@/lib/course-resources";
import { isAdmin } from "@/lib/admin";

const user = Astro.locals.user!;
const env = Astro.locals.runtime.env;
const db = getDb(env);

const { courseSlug } = Astro.params;
const course = await getCourseBySlug(db, courseSlug!);
if (!course) return Astro.redirect("/dashboard", 302);

const structure = await getCourseStructure(db, course.id);
const enrolled = await hasActiveEnrollment(db, user.id, course.id);
const seat = await getCourseSeatTime(db, user.id, course.id);

const fmtMin = (s: number) => (s / 60).toFixed(0);
const pct = Math.round(seat.watchedFraction * 100);
const thresholdPct = Math.round(seat.completionThreshold * 100);
const lessonsRemaining = seat.perLesson.filter((p) => !p.meetsThreshold).length;

// Quick lookup: per-lesson credited seconds.
const lessonCredit = new Map(seat.perLesson.map((p) => [p.lessonId, p]));

// Quizzes: each module's knowledge check + the course final exam.
const moduleQuiz = new Map<string, { id: string; passed: boolean }>();
for (const { module } of structure) {
  if (!(module.isFreePreview || enrolled)) continue;
  const q = await getModuleQuiz(db, module.id);
  if (q) moduleQuiz.set(module.id, { id: q.id, passed: false });
}
const finalExam = await getFinalExam(db, course.id);
const finalPassed = finalExam ? await hasPassed(db, user.id, finalExam.id) : false;

// Certificate (issued when the final exam is passed). Self-heal: if they passed
// but have no certificate yet (e.g. legal name added after the exam, or a prior
// issuance error), issue + email it now. Idempotent.
let certificate = (await getActiveCertificate(db, user.id, course.id)) ?? null;
if (!certificate && finalPassed && user.legalName.trim()) {
  const issued = await issueAndEmailCertificate(env, db, {
    userId: user.id,
    courseId: course.id,
    email: user.email,
  });
  certificate = issued?.certificate ?? null;
}
const needsLegalName = finalPassed && !certificate && !user.legalName.trim();

// Downloadable course resources (e.g. the Vitals practice-log PDF).
// Enrolled students and public resources as usual; admins always see them too
// (so the owner can verify published collateral without enrolling).
const admin = isAdmin(env, user);
const resources = (await listCourseResources(db, course.id)).filter(
  (r) => r.visibility === "public" || enrolled || admin,
);
---

<Layout title={course.title} showNav={true}>
  <p style="margin:0"><a href="/dashboard">← Dashboard</a></p>
  <h1>{course.title}</h1>
  {course.description && <p style="margin-top:0">{course.description}</p>}

  <p style="margin:0 0 1rem">
    <a class="btn" href={`/learn/${course.slug}/tutor`}>💬 Ask the course tutor</a>
  </p>

  {
    resources.length > 0 && (
      <div class="panel">
        <h2 style="margin-top:0">Downloads</h2>
        <ul style="list-style:none;padding:0;margin:0">
          {resources.map((r) => (
            <li style="padding:0.35rem 0;border-top:1px solid var(--border)">
              📄{" "}
              <a href={`/learn/${course.slug}/resources/${r.id}`}>{r.title}</a>
              {r.type === "practice_log_template" && (
                <span class="muted" style="font-size:0.85rem"> — print and track your practice</span>
              )}
            </li>
          ))}
        </ul>
      </div>
    )
  }

  {Astro.url.searchParams.get("comped") && (
    <div class="notice ok">You're enrolled (comped — test mode, no charge). The full course is unlocked.</div>
  )}
  {Astro.url.searchParams.get("canceled") && (
    <div class="notice warn">Checkout canceled — you can enroll any time.</div>
  )}

  <div class="panel">
    <h2>Your progress</h2>
    <p style="margin-top:0">
      Course content watched:{" "}
      <strong style="color:var(--text)">{pct}%</strong>{" "}
      ({fmtMin(seat.creditedSeconds)} of {fmtMin(seat.totalContentSeconds)} min).
    </p>
    <div style="height:10px;background:var(--brand-tint);border-radius:6px;overflow:hidden;border:1px solid var(--border)">
      <div style={`height:100%;width:${pct}%;background:var(--accent)`}></div>
    </div>
    <p class="muted" style="margin:0.75rem 0 0">
      {seat.examUnlocked
        ? "✓ You've watched the required content — the final exam is unlocked."
        : `The final exam unlocks once you've watched at least ${thresholdPct}% of every lesson${lessonsRemaining > 0 ? ` (${lessonsRemaining} lesson${lessonsRemaining === 1 ? "" : "s"} to go)` : ""}.`}
    </p>
  </div>

  {
    structure.map(({ module, lessons }) => {
      const unlocked = module.isFreePreview || enrolled;
      return (
        <div class="panel">
          <div style="display:flex;align-items:center;gap:0.5rem">
            <h2 style="margin:0">
              {module.position}. {module.title}
            </h2>
            {module.isFreePreview && (
              <span style="font-size:0.75rem;color:var(--ok);border:1px solid var(--ok);border-radius:999px;padding:0.1rem 0.5rem">
                Free preview
              </span>
            )}
            {!unlocked && (
              <span style="font-size:0.75rem;color:var(--muted);border:1px solid var(--border);border-radius:999px;padding:0.1rem 0.5rem">
                🔒 Locked
              </span>
            )}
          </div>
          {module.description && <p style="margin:0.4rem 0 0">{module.description}</p>}

          <ol style="list-style:none;padding:0;margin:0.75rem 0 0">
            {lessons.map((lesson) => {
              const p = lessonCredit.get(lesson.id);
              const done = p?.complete;
              return (
                <li style="display:flex;align-items:center;gap:0.75rem;padding:0.6rem 0;border-top:1px solid var(--border)">
                  <span style="flex:1">
                    {unlocked ? (
                      <a href={`/learn/${course.slug}/${module.id}/${lesson.id}`}>
                        {lesson.title}
                      </a>
                    ) : (
                      <span class="muted">{lesson.title}</span>
                    )}
                  </span>
                  <span class="muted" style="font-size:0.8rem">
                    {done
                      ? "✓ complete"
                      : p && p.creditedSeconds > 0
                        ? `${fmtMin(p.creditedSeconds)}/${fmtMin(lesson.durationSeconds)} min`
                        : `${fmtMin(lesson.durationSeconds)} min`}
                  </span>
                </li>
              );
            })}
          </ol>

          {unlocked && moduleQuiz.has(module.id) && (
            lessons.length > 0 && !lessons.every((l) => lessonCredit.get(l.id)?.meetsThreshold) ? (
              <p class="muted" style="margin:0.75rem 0 0">
                🔒 Knowledge check unlocks after you watch ≥{thresholdPct}% of the module's
                video{lessons.length === 1 ? "" : "s"}.
              </p>
            ) : (
              <p style="margin:0.75rem 0 0">
                <a href={`/learn/${course.slug}/quiz/${moduleQuiz.get(module.id)!.id}`}>
                  Knowledge check →
                </a>
              </p>
            )
          )}

          {!unlocked && (
            <div style="margin:0.75rem 0 0">
              <p class="muted" style="margin:0 0 0.5rem">
                This module is part of the paid course.
              </p>
              <form method="POST" action="/api/checkout/course">
                <input type="hidden" name="courseId" value={course.id} />
                <button type="submit" style="margin:0">
                  Enroll — ${(course.priceCents / 100).toFixed(0)}
                </button>
              </form>
            </div>
          )}
        </div>
      );
    })
  }

  <div class="panel">
    <h2>Final exam {finalPassed && <span style="color:var(--ok);font-size:0.9rem">· ✓ passed</span>}</h2>
    <div class="notice" style="background:var(--brand-tint);border:1px solid var(--brand);color:var(--ink)">
      <strong>Not the certification exam.</strong> This confirms you understood the
      training material. It does <strong>not</strong> certify you — Oregon CA
      certification requires the separate exam administered through the NBCE.
    </div>
    {
      !finalExam ? (
        <p style="margin-top:0">The final exam isn't published yet.</p>
      ) : !enrolled ? (
        <p style="margin-top:0">Enroll in the course to take the final exam.</p>
      ) : seat.examUnlocked ? (
        <p style="margin-top:0">
          <a class="btn" href={`/learn/${course.slug}/quiz/${finalExam.id}`}>
            {finalPassed ? "Review the final exam" : "Take the final exam"} →
          </a>
        </p>
      ) : (
        <p style="margin-top:0">
          Locked until you reach the required content time above.
        </p>
      )
    }
  </div>

  {
    certificate && (
      <div class="panel" style="border-color:var(--success)">
        <h2 style="color:var(--success);margin-bottom:0.25rem">🎓 Certificate earned</h2>
        <p style="margin-top:0">
          Certificate <strong>{certificate.certNumber}</strong> — issued to{" "}
          {certificate.legalNameSnapshot}. A copy was emailed to you.
        </p>
        <p style="margin:0">
          <a class="btn" href={`/certificate/${certificate.verificationCode}.pdf`}>
            Download certificate (PDF)
          </a>
        </p>
        <p class="muted" style="margin:0.75rem 0 0;font-size:0.9rem">
          Verification code <strong>{certificate.verificationCode}</strong> ·{" "}
          <a href={`/verify/${certificate.verificationCode}`}>public verify page</a>
        </p>
      </div>
    )
  }

  {
    needsLegalName && (
      <div class="panel" style="border-color:var(--warn)">
        <h2 style="color:var(--warn)">One step left for your certificate</h2>
        <p style="margin-top:0">
          You passed the final exam, but we need your full legal name before we
          can issue your certificate.{" "}
          <a href="/intake">Add your legal name</a> and it will be issued
          automatically.
        </p>
      </div>
    )
  }
</Layout>
