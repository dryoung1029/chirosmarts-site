# Copy this file to `.dev.vars` and fill in real values for local development.
# `.dev.vars` is git-ignored and must NEVER be committed.
# Wrangler loads `.dev.vars` automatically for `astro dev` and `wrangler` commands.

# Public site URL — used for magic-link emails, Stripe redirect URLs, and
# certificate verification links. Never hard-code these URLs anywhere.
# Local: http://localhost:4322  |  Deployed: https://chirosmarts-site.pages.dev
# (ChiroSmarts uses 4322 to avoid clashing with other Astro projects on 4321.)
SITE_URL="http://localhost:4322"

# Comma-separated emails granted the /admin area (promoted to site_admin on login).
ADMIN_EMAILS="you@example.com"

# --- Resend (transactional + compliance email: magic links, receipts, certs) ---
# If RESEND_API_KEY is empty, sign-in links are printed to the dev server console
# (and shown on the login page) instead of emailed, so you can test without a key.
RESEND_API_KEY=""
# From address for transactional email. For Resend testing without a verified
# domain, "onboarding@resend.dev" works (delivers to your own account email).
EMAIL_FROM="ChiroSmarts <onboarding@resend.dev>"

# --- Stripe (test mode throughout the build) ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Cloudflare Stream (signed playback tokens; not a wrangler binding) ---
# CF_ACCOUNT_ID + CF_STREAM_API_TOKEN are used by scripts/upload-to-stream.
# The signing key (created once via the /stream/keys API) lets the Worker mint
# short-lived RS256 playback tokens without calling the Stream API per request.
# CF_STREAM_CUSTOMER_CODE is the "customer-<code>" playback subdomain.
# If these are empty, the lesson player falls back to a dev simulator so
# seat-time can still be exercised locally without real video.
CF_ACCOUNT_ID=""
CF_STREAM_API_TOKEN=""
CF_STREAM_CUSTOMER_CODE=""
CF_STREAM_SIGNING_KEY_ID=""
CF_STREAM_SIGNING_KEY_PEM=""
CF_STREAM_SIGNING_KEY_JWK=""

# --- Anthropic API (M6 AI course tutor — Claude Haiku 4.5) ---
# Without a key the tutor still runs but answers "not configured yet".
ANTHROPIC_API_KEY=""

# --- Marketing layer ---
# Cloudflare Web Analytics beacon token (cookieless). Injected into marketing
# pages only when set. View stats in Cloudflare dashboard → Web Analytics.
CF_WEB_ANALYTICS_TOKEN=""
# Brevo (marketing email). Groundwork only — manual admin sync of CONSENTED
# contacts; no campaigns. List IDs are numeric.
BREVO_API_KEY=""
BREVO_LIST_ID_LEADS=""
BREVO_LIST_ID_USERS=""
