# build output
dist/
.astro/

# dependencies
node_modules/

# secrets & local env — NEVER commit
.dev.vars
.dev.vars.*
!.dev.vars.example
.env
.env.*

# cloudflare / wrangler local state
.wrangler/

# logs & os
npm-debug.log*
*.log
.DS_Store

# Vendored Jeldon engine ships its prebuilt dist (no registry yet — see
# vendor/jeldon/README.md). Keep it tracked despite the global `dist/` rule.
!vendor/jeldon/**/dist/
!vendor/jeldon/**/dist/**
